{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Board Portal",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/SamorodinkaTech.Fiducia.BoardPortal/bin/Debug/net9.0/SamorodinkaTech.Fiducia.BoardPortal.dll",
            "cwd": "${workspaceFolder}/SamorodinkaTech.Fiducia.BoardPortal",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5000"
            },
            "launchBrowser": {
                "enabled": true,
                "args": "${auto-detect-url}",
                "windows": {
                    "command": "cmd.exe",
                    "args": "/C start ${auto-detect-url}"
                },
                "osx": {
                    "command": "open",
                    "args": "${auto-detect-url}/login"
                }
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ]
}
