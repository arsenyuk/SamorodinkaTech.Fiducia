{
  "DetailedErrors": true,
  "Ldap": {
    "Enabled": true,
    "Server": "localhost",
    "Port": 389,
    "BaseDn": "dc=bryansk-arsenal,dc=local",
    "BindUser": "cn=admin,dc=bryansk-arsenal,dc=local",
    "BindPassword": "admin",
    "BoardGroupDn": "cn=BoardOfDirectors,ou=Groups,dc=bryansk-arsenal,dc=local",
    "SysAdminGroupDn": "cn=SysAdmins,ou=Groups,dc=bryansk-arsenal,dc=local"
  },
  "SecurityAudit": {
    "StoragePath": "./logs/audit"
  },
  "ApplicationLogging": {
    "StoragePath": "./logs/app"
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalBasePath": "../storage"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SamorodinkaTech.Fiducia": "Debug",
      "JwtAuth": "Debug",
      "SessionApi": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/app/app-.log",
          "rollingInterval": "Hour",
          "retainedFileCountLimit": 72,
          "fileSizeLimitBytes": 104857600,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        },
        "Filter": [
          {
            "Name": "ByExcluding",
            "Args": { "expression": "AuditLog is not null" }
          }
        ]
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": { "expression": "SourceContext like 'SamorodinkaTech.Fiducia.Infrastructure.Auditing.SecurityAuditService%'" }
              }
            ],
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "./logs/audit/audit-.log",
                  "rollingInterval": "Hour",
                  "retainedFileCountLimit": 168,
                  "outputTemplate": "{Message:lj}{NewLine}"
                }
              }
            ]
          }
        }
      }
    ]
  }
}
