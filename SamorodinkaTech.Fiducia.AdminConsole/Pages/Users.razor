@page "/users"
@using Microsoft.EntityFrameworkCore
@using SamorodinkaTech.Fiducia.Domain.Entities
@using SamorodinkaTech.Fiducia.Domain.Interfaces
@inject IApplicationDbContext DbContext
@inject NavigationManager Navigation

<PageTitle>Fiducia — Пользователи</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Пользователи</h3>
        <div>
            <button class="btn btn-outline-primary me-2" @onclick="ShowInviteModal">
                Пригласить внешнего директора
            </button>
            <button class="btn btn-primary" @onclick="ShowCreateModal">+ Добавить</button>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ФИО</th>
                        <th>Роли в СД</th>
                        <th>Статус выбытия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in _userRows)
                    {
                        <tr style="cursor: pointer;" @onclick="() => OpenUser(user.UserId)">
                            <td><strong>@user.FullName</strong></td>
                            <td>@user.BoardRoles</td>
                            <td>@user.ResignationStatus</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Модальное окно создания пользователя -->
@if (_showCreateModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Добавить пользователя</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Фамилия *</label>
                        <input type="text" class="form-control" @bind="_newLastName">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Имя *</label>
                        <input type="text" class="form-control" @bind="_newFirstName">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Отчество</label>
                        <input type="text" class="form-control" @bind="_newMiddleName">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email *</label>
                        <input type="email" class="form-control" @bind="_newEmail">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Телефон *</label>
                        <input type="tel" class="form-control" @bind="_newPhone">
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" @bind="_newIsExternal">
                        <label class="form-check-label">Внешний директор</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Отмена</button>
                    <button type="button" class="btn btn-primary" @onclick="CreateUser">Создать</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Модальное окно инвайта -->
@if (_showInviteModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Пригласить внешнего директора</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Email *</label>
                        <input type="email" class="form-control" @bind="_inviteEmail">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Фамилия *</label>
                        <input type="text" class="form-control" @bind="_inviteLastName">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Имя *</label>
                        <input type="text" class="form-control" @bind="_inviteFirstName">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Телефон *</label>
                        <input type="tel" class="form-control" @bind="_invitePhone">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Срок действия (дней)</label>
                        <input type="number" class="form-control" @bind="_inviteExpiryDays" min="1" max="30">
                    </div>

                    @if (!string.IsNullOrEmpty(_inviteLink))
                    {
                        <div class="alert alert-success">
                            <strong>Инвайт-ссылка создана:</strong>
                            <div class="input-group mt-2">
                                <input type="text" class="form-control" value="@_inviteLink" readonly>
                                <button class="btn btn-outline-secondary" @onclick="CopyToClipboard">Копировать</button>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Закрыть</button>
                    <button type="button" class="btn btn-primary" @onclick="GenerateInvite"
                            disabled="@(_isGenerating || string.IsNullOrWhiteSpace(_inviteEmail))">
                        @if (_isGenerating)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Создать ссылку
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UserRow> _userRows = new();

    // Создание пользователя
    private bool _showCreateModal;
    private string _newLastName = string.Empty;
    private string _newFirstName = string.Empty;
    private string _newMiddleName = string.Empty;
    private string _newEmail = string.Empty;
    private string _newPhone = string.Empty;
    private bool _newIsExternal;

    // Инвайт
    private bool _showInviteModal;
    private bool _isGenerating;
    private string _inviteEmail = string.Empty;
    private string _inviteLastName = string.Empty;
    private string _inviteFirstName = string.Empty;
    private string _invitePhone = string.Empty;
    private int _inviteExpiryDays = 7;
    private string _inviteLink = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var users = await DbContext.Users.AsNoTracking().ToListAsync();

        var appointments = await DbContext.BoardMemberAppointments
            .AsNoTracking()
            .Include(a => a.BoardMember)
            .Include(a => a.Role)
            .Where(a => a.BoardMember!.UserId != null)
            .ToListAsync();

        var rolesByUser = appointments
            .GroupBy(a => a.BoardMember!.UserId!.Value)
            .ToDictionary(
                g => g.Key,
                g => string.Join(", ", g.Select(a => a.Role!.Name).Distinct().OrderBy(n => n)));

        var resignations = await DbContext.UserBoardMemberResignations
            .AsNoTracking()
            .Include(r => r.ResignationReason)
            .OrderByDescending(r => r.ResignedAt)
            .ToListAsync();

        var latestResignationByUser = resignations
            .GroupBy(r => r.UserId)
            .ToDictionary(g => g.Key, g => g.First());

        _userRows = users.Select(u =>
        {
            var fullName = string.Join(" ",
                new[] { u.LastName, u.FirstName, u.MiddleName }.Where(s => !string.IsNullOrWhiteSpace(s)));

            rolesByUser.TryGetValue(u.Id, out var roles);
            var boardRoles = !string.IsNullOrEmpty(roles) ? roles : "—";

            var resignationStatus = "—";
            if (latestResignationByUser.TryGetValue(u.Id, out var r))
            {
                var date = r.ResignedAt.ToString("dd.MM.yyyy");
                var reason = r.ResignationReason?.Name ?? r.ResignationReason?.Code ?? "—";
                resignationStatus = $"Выбыл: {reason}, {date}";
            }

            return new UserRow(u.Id, fullName, boardRoles, resignationStatus);
        }).OrderBy(r => r.FullName).ToList();
    }

    private void OpenUser(Guid userId)
    {
        Navigation.NavigateTo($"/users/{userId}");
    }

    private void ShowCreateModal()
    {
        _showCreateModal = true;
        _showInviteModal = false;
    }

    private void ShowInviteModal()
    {
        _showInviteModal = true;
        _showCreateModal = false;
        _inviteLink = string.Empty;
    }

    private void CloseModals()
    {
        _showCreateModal = false;
        _showInviteModal = false;
    }

    private async Task CreateUser()
    {
        var user = new User
        {
            LastName = _newLastName,
            FirstName = _newFirstName,
            MiddleName = _newMiddleName,
            Email = _newEmail,
            Phone = _newPhone,
            IsExternal = _newIsExternal,
            CreatedAt = DateTime.UtcNow
        };

        DbContext.Users.Add(user);
        await DbContext.SaveChangesAsync();

        CloseModals();
        await OnInitializedAsync();
    }

    private async Task GenerateInvite()
    {
        _isGenerating = true;

        try
        {
            var token = Guid.NewGuid().ToString("N");
            var expiresAt = DateTime.UtcNow.AddDays(_inviteExpiryDays);

            var user = new User
            {
                LastName = _inviteLastName,
                FirstName = _inviteFirstName,
                Email = _inviteEmail,
                Phone = _invitePhone,
                IsExternal = true,
                InvitationToken = token,
                InvitationExpiresAt = expiresAt,
                CreatedAt = DateTime.UtcNow
            };

            DbContext.Users.Add(user);
            await DbContext.SaveChangesAsync();

            _inviteLink = $"http://localhost:5000/onboarding/{token}";
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task CopyToClipboard()
    {
        await Task.CompletedTask;
    }

    private record UserRow(Guid UserId, string FullName, string BoardRoles, string ResignationStatus);
}
