@page "/sent-notifications"
@using SamorodinkaTech.Fiducia.Domain.Entities
@using SamorodinkaTech.Fiducia.Domain.Interfaces
@inject IApplicationDbContext DbContext

<PageTitle>Fiducia — Отправленные уведомления</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Отправленные уведомления</h3>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" style="width: 200px;" @onchange="OnFilterChanged">
                <option value="">Все комитеты</option>
                @foreach (var committee in _committees)
                {
                    <option value="@committee.Id">@committee.Name</option>
                }
            </select>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            @if (_notifications.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <p class="mb-0">Уведомления не найдены</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Дата</th>
                                <th>Тип</th>
                                <th>Заголовок</th>
                                <th>Получатель</th>
                                <th>Комитет</th>
                                <th>Статус</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var notification in _notifications)
                            {
                                <tr>
                                    <td><small class="text-muted">@notification.Id</small></td>
                                    <td><small>@notification.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small></td>
                                    <td>
                                        <span class="badge @GetNotificationTypeBadge(notification.NotificationType)">
                                            @GetNotificationTypeLabel(notification.NotificationType)
                                        </span>
                                    </td>
                                    <td>@notification.Title</td>
                                    <td>@(notification.User != null ? $"{notification.User.LastName} {notification.User.FirstName}" : "—")</td>
                                    <td>@(notification.Committee?.Name ?? "—")</td>
                                    <td>
                                        @if (notification.IsRead)
                                        {
                                            <span class="badge bg-success">Прочитано</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Непрочитано</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Notification> _notifications = new();
    private List<Committee> _committees = new();
    private Guid? _filterCommitteeId;

    protected override async Task OnInitializedAsync()
    {
        _committees = await DbContext.Committees
            .Where(c => c.IsActive)
            .OrderBy(c => c.Name)
            .ToListAsync();

        await LoadNotifications();
    }

    private async Task LoadNotifications()
    {
        var query = DbContext.Notifications
            .Include(n => n.User)
            .Include(n => n.Committee)
            .Include(n => n.Meeting)
            .AsQueryable();

        if (_filterCommitteeId.HasValue)
        {
            query = query.Where(n => n.CommitteeId == _filterCommitteeId.Value);
        }

        _notifications = await query
            .OrderByDescending(n => n.CreatedAt)
            .Take(200)
            .ToListAsync();
    }

    private async Task OnFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        _filterCommitteeId = string.IsNullOrEmpty(value) ? null : Guid.Parse(value);
        await LoadNotifications();
    }

    private string GetNotificationTypeBadge(string type)
    {
        return type switch
        {
            "MEETING_SUMMONS" => "bg-primary",
            "VOTE_REMINDER" => "bg-info",
            "PROTOCOL_SIGNED" => "bg-success",
            "COMMITTEE_PROTOCOL_SIGNED" => "bg-warning",
            "VOTE_DEADLINE" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetNotificationTypeLabel(string type)
    {
        return type switch
        {
            "MEETING_SUMMONS" => "Созыв",
            "VOTE_REMINDER" => "Напоминание",
            "PROTOCOL_SIGNED" => "Протокол подписан",
            "COMMITTEE_PROTOCOL_SIGNED" => "Протокол комитета",
            "VOTE_DEADLINE" => "Дедлайн",
            _ => "Общее"
        };
    }
}
