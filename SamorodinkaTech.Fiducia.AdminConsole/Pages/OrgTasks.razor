@page "/org-templates/offers/{OfferId:guid}/tasks"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SamorodinkaTech.Fiducia.Infrastructure.Persistence.FiduciaDbContext> DbFactory
@inject ILogger<OrgTemplates> Logger
@inject NavigationManager Nav
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SYS_ADMIN")]

<h3>
    <a href="/org-templates" class="text-decoration-none">Шаблоны</a> →
    @if (_stageId.HasValue)
    {
        <span>→ </span>
        <a href="/org-templates/stages/@_stageId/offers" class="text-decoration-none">@(_stageName ?? "Оферы")</a>
    }
    <span>→ @(_offerName ?? "Задачи")</span>
</h3>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="alert alert-danger">@_error</div>
}
@if (!string.IsNullOrEmpty(_success))
{
    <div class="alert alert-success">@_success</div>
}

<button class="btn btn-primary btn-sm mb-2" @onclick="() => _showForm = true">Добавить задачу</button>

@if (_showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Название</label>
                    <input class="form-control" @bind="_editName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Описание</label>
                    <input class="form-control" @bind="_editDesc" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Роль</label>
                    <select class="form-select" @bind="_editRoleId">
                        <option value="">— нет —</option>
                        @foreach (var r in _roles)
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label">Порядок</label>
                    <input class="form-control" type="number" @bind="_editSort" />
                </div>
                <div class="col-md-1 d-flex gap-1">
                    <button class="btn btn-success btn-sm" @onclick="Save">✓</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelForm">✕</button>
                </div>
            </div>
        </div>
    </div>
}

<table class="table table-sm table-hover">
    <thead>
        <tr><th>Название</th><th>Описание</th><th>Роль</th><th style="width:80px">Порядок</th><th style="width:100px">Действия</th></tr>
    </thead>
    <tbody>
    @foreach (var t in _items)
    {
        var roleName = _roles.FirstOrDefault(r => r.Id == t.AssignedRoleId)?.Name ?? "—";
        <tr>
            <td>@t.Name</td>
            <td class="text-muted small">@t.Description</td>
            <td>@roleName</td>
            <td>@t.SortOrder</td>
            <td>
                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => Edit(t)">✏️</button>
                <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(t)">🗑️</button>
            </td>
        </tr>
    }
    </tbody>
</table>

@code {
    [Parameter] public Guid OfferId { get; set; }

    private List<TplOrgTask> _items = new();
    private List<Role> _roles = new();
    private string? _offerName;
    private string? _stageName;
    private Guid? _stageId;
    private string? _error;
    private string? _success;
    private bool _showForm;
    private string _editName = "";
    private string _editDesc = "";
    private string _editRoleId = "";
    private int _editSort;
    private Guid? _editingId;

    protected override async Task OnInitializedAsync() { await LoadAsync(); }

    private async Task LoadAsync()
    {
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var offer = await ctx.TplOrgOffers.Include(x => x.Stage).ThenInclude(x => x!.Intent).FirstOrDefaultAsync(x => x.Id == OfferId);
            if (offer != null)
            {
                _offerName = offer.Name;
                _stageId = offer.StageId;
                _stageName = offer.Stage?.Name;
            }
            _items = await ctx.TplOrgTasks.Where(x => x.OfferId == OfferId).OrderBy(x => x.SortOrder).ThenBy(x => x.Name).ToListAsync();
            _roles = await ctx.Roles.OrderBy(x => x.Name).ToListAsync();
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Ошибка загрузки задач"); _error = ExceptionFlattener.Unwrap(ex); }
    }

    private void Edit(TplOrgTask t)
    {
        _editingId = t.Id; _editName = t.Name; _editDesc = t.Description ?? "";
        _editRoleId = t.AssignedRoleId?.ToString() ?? ""; _editSort = t.SortOrder; _showForm = true;
    }

    private void CancelForm() { _showForm = false; _editingId = null; }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            if (_editingId.HasValue)
            {
                var e = await ctx.TplOrgTasks.FirstOrDefaultAsync(x => x.Id == _editingId.Value);
                if (e != null)
                {
                    e.Name = _editName.Trim(); e.Description = (string.IsNullOrWhiteSpace(_editDesc) ? null : _editDesc.Trim());
                    e.AssignedRoleId = string.IsNullOrWhiteSpace(_editRoleId) ? null : Guid.Parse(_editRoleId); e.SortOrder = _editSort;
                }
            }
            else
            {
                ctx.TplOrgTasks.Add(new TplOrgTask { Id = Guid.NewGuid(), Name = _editName.Trim(), Description = (string.IsNullOrWhiteSpace(_editDesc) ? null : _editDesc.Trim()), OfferId = OfferId,
                    AssignedRoleId = string.IsNullOrWhiteSpace(_editRoleId) ? null : Guid.Parse(_editRoleId), SortOrder = _editSort });
            }
            await ctx.SaveChangesAsync();
            CancelForm(); await LoadAsync();
            _success = _editingId.HasValue ? "Задача обновлена." : "Задача создана.";
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Ошибка сохранения"); _error = ExceptionFlattener.Unwrap(ex); }
    }

    private async Task Delete(TplOrgTask t)
    {
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var e = await ctx.TplOrgTasks.FirstOrDefaultAsync(x => x.Id == t.Id);
            if (e != null) { ctx.TplOrgTasks.Remove(e); await ctx.SaveChangesAsync(); await LoadAsync(); _success = "Задача удалена."; }
        }
        catch (Exception ex) { Logger.LogWarning(ex, "Ошибка удаления"); _error = ExceptionFlattener.Unwrap(ex); }
    }
}
