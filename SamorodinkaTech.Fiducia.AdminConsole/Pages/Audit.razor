@page "/audit"
@using SamorodinkaTech.Fiducia.Domain.Entities
@using SamorodinkaTech.Fiducia.Domain.Interfaces
@inject IApplicationDbContext DbContext

<PageTitle>Fiducia — Журнал аудита</PageTitle>

<div class="container-fluid">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Журнал аудита безопасности</h5>
            <button class="btn btn-sm btn-primary">Экспорт CSV</button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Время (UTC)</th>
                            <th>Пользователь</th>
                            <th>IP</th>
                            <th>Действие</th>
                            <th>Описание</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in _auditLogs)
                        {
                            <tr>
                                <td><small class="text-muted">@log.Id</small></td>
                                <td><small>@log.LogTimestamp.ToString("yyyy-MM-dd HH:mm:ss")</small></td>
                                <td>@(log.UserId?.ToString() ?? "—")</td>
                                <td><small>@log.UserIp</small></td>
                                <td>
                                    <span class="badge @GetBadgeClass(log.ActionCode)">@log.ActionCode</span>
                                </td>
                                <td>@log.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<SecurityAuditLog> _auditLogs = new();

    protected override async Task OnInitializedAsync()
    {
        _auditLogs = await DbContext.SecurityAuditLogs
            .OrderByDescending(l => l.LogTimestamp)
            .Take(100)
            .ToListAsync();
    }

    private string GetBadgeClass(string actionCode)
    {
        return actionCode switch
        {
            "LOGIN_SUCCESS" => "bg-success",
            "LOGIN_FAILED" => "bg-danger",
            "VOTE_SUBMIT" => "bg-warning",
            "DOCUMENT_VIEW" => "bg-info",
            "ACCESS_DENIED" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
