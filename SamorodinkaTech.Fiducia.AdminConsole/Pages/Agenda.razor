@page "/agenda"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<SamorodinkaTech.Fiducia.Infrastructure.Persistence.FiduciaDbContext> DbFactory
@inject ILogger<Agenda> Logger
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SYS_ADMIN")]
@using SamorodinkaTech.Fiducia.Domain.Entities

<h3>Повестки будущих заседаний</h3>

@if (_items.Count == 0)
{
    <p class="text-muted">Нет ожидающих повесток.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Создана</th>
                <th>Цель</th>
                <th>Повестка</th>
                <th>Причина</th>
                <th>Совет директоров</th>
                <th>Статус</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _items)
            {
                <tr>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <span class="badge @(item.TargetType == "BOARD_MEETING" ? "bg-primary" : "bg-warning text-dark")">
                            @(item.TargetType == "BOARD_MEETING" ? "Заседание СД" : "ОСА / ВОСА")
                        </span>
                    </td>
                    <td>@item.Title</td>
                    <td>@item.Reason</td>
                    <td>
                        <a href="/board-of-directors/@item.BoardOfDirectorsId" class="text-decoration-none">
                            СД @(item.BoardGosaYear?.ToString() ?? "—")
                        </a>
                    </td>
                    <td>
                        <span class="badge bg-secondary">@item.Status</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<AgendaItemView> _items = new();

    private record AgendaItemView
    {
        public Guid Id { get; init; }
        public string Title { get; init; } = default!;
        public string TargetType { get; init; } = default!;
        public string Reason { get; init; } = default!;
        public string Status { get; init; } = default!;
        public DateTime CreatedAt { get; init; }
        public Guid BoardOfDirectorsId { get; init; }
        public int? BoardGosaYear { get; init; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            _items = await ctx.AgendaItems
                .OrderByDescending(a => a.CreatedAt)
                .Select(a => new AgendaItemView
                {
                    Id = a.Id,
                    Title = a.Title,
                    TargetType = a.TargetType,
                    Reason = a.Reason,
                    Status = a.Status,
                    CreatedAt = a.CreatedAt,
                    BoardOfDirectorsId = a.BoardOfDirectorsId,
                    BoardGosaYear = ctx.BoardsOfDirectors
                        .Where(b => b.Id == a.BoardOfDirectorsId)
                        .Select(b => b.GosaYear)
                        .FirstOrDefault()
                })
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Ошибка загрузки повесток");
        }
    }
}
