@page "/admin/board-of-directors"
@attribute [Authorize(Roles = "SYS_ADMIN")]
@using Microsoft.EntityFrameworkCore
@inject IServiceProvider ServiceProvider
@inject ILogger<BoardOfDirectors> Logger
@using SamorodinkaTech.Fiducia.Domain.Interfaces
@using SamorodinkaTech.Fiducia.Domain.Entities

<h3>Совет директоров — Ключевые правовые нормы</h3>

<div class="card mb-3">
    <div class="card-header">
        <strong>Опции совета директоров</strong>
    </div>
    <div class="card-body">
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="optDeputyChair"
                   checked="@_deputyChairProvided" @onchange="() => _deputyChairProvided = !_deputyChairProvided">
            <label class="form-check-label" for="optDeputyChair">Предусмотрен Заместитель Председателя СД</label>
        </div>
        <div class="form-check form-switch mt-2">
            <input class="form-check-input" type="checkbox" role="switch" id="optSecretary"
                   checked="@_secretaryProvided" @onchange="() => _secretaryProvided = !_secretaryProvided">
            <label class="form-check-label" for="optSecretary">Предусмотрен Секретарь СД</label>
        </div>
        <div class="form-check form-switch mt-2">
            <input class="form-check-input" type="checkbox" role="switch" id="optSecretarySigns"
                   checked="@_secretarySignsProtocols" @onchange="() => _secretarySignsProtocols = !_secretarySignsProtocols" disabled="@(!_secretaryProvided)">
            <label class="form-check-label" for="optSecretarySigns">Секретарь подписывает протоколы СД</label>
        </div>
        <small class="text-muted">Опция организационного устройства общества; допускается внутренними документами. Закон № 208-ФЗ напрямую не обязывает наличие Заместителя.</small>

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="SaveOptions">Сохранить</button>
            <button class="btn btn-outline-secondary" @onclick="CancelOptions">Отмена</button>
        </div>
        @if (!string.IsNullOrEmpty(_status))
        {
            <div class="mt-2"><small class="@_statusCss">@_status</small></div>
        }
    </div>
 </div>

<p class="text-muted">Документ подготовлен на основе норм действующего законодательства РФ по состоянию на 2026 год.</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Действие</th>
            <th>Правовое основание</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Избрание СД на ОСА</td>
            <td>п. 1, 3 ст. 66 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>Кумулятивное голосование</td>
            <td>п. 4 ст. 66 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>Срок полномочий СД — до следующего ГОСА</td>
            <td>п. 1 ст. 66 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>ГОСА — с 1 марта по 30 июня</td>
            <td>п. 3 ст. 47 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>Протокол ОСА — не позднее 3 рабочих дней</td>
            <td>п. 1 ст. 63 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>Избрание Председателя СД</td>
            <td>п. 2 ст. 66 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>Председатель не может быть Генеральным директором</td>
            <td>п. 2 ст. 66 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>При отсутствии Председателя — один из членов СД</td>
            <td>п. 3 ст. 67 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>Кворум СД — не менее половины от числа избранных членов</td>
            <td>п. 2 ст. 68 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>Протокол СД подписывается Председателем и Секретарем (если есть)</td>
            <td>п. 4 ст. 68 Закона № 208-ФЗ</td>
        </tr>
        <tr>
            <td>Секретарь СД — не обязан, может быть назначен</td>
            <td>п. 1 ст. 68 Закона № 208-ФЗ</td>
        </tr>
    </tbody>
    <caption>*Документ подготовлен на основе норм действующего законодательства РФ по состоянию на 2026 год.</caption>
    
</table>

@code {
    private bool _deputyChairProvided = false;
    private bool _secretaryProvided = true; // по умолчанию предусмотрен
    private bool _lastSavedDeputy;
    private bool _lastSavedSecretary;
    private bool _lastSavedSecretarySigns;
    private string? _status;
    private string _statusCss = "text-success";
    private bool _secretarySignsProtocols = false;

    protected override async Task OnInitializedAsync()
    {
        // Глобальные настройки СД (singleton, BDR‑007) — не привязаны к ЮЛ
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<IApplicationDbContext>();
        var settings = await db.LegalEntityBoardSettings.FirstOrDefaultAsync();
        if (settings != null)
        {
            _deputyChairProvided = settings.DeputyChairProvided;
            _secretaryProvided = settings.SecretaryProvided;
            _secretarySignsProtocols = settings.SecretarySignsProtocols;
        }

        _lastSavedDeputy = _deputyChairProvided;
        _lastSavedSecretary = _secretaryProvided;
        _lastSavedSecretarySigns = _secretarySignsProtocols;
    }

    private async Task SaveOptions()
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<IApplicationDbContext>();
            var ef = (DbContext)db;

            var settings = await db.LegalEntityBoardSettings.FirstOrDefaultAsync();
            if (settings == null)
            {
                settings = new LegalEntityBoardSettings
                {
                    Id = Guid.NewGuid(),
                    DeputyChairProvided = _deputyChairProvided,
                    SecretaryProvided = _secretaryProvided,
                    SecretarySignsProtocols = _secretaryProvided && _secretarySignsProtocols
                };
                await db.LegalEntityBoardSettings.AddAsync(settings);
            }
            else
            {
                settings.DeputyChairProvided = _deputyChairProvided;
                settings.SecretaryProvided = _secretaryProvided;
                settings.SecretarySignsProtocols = _secretaryProvided && _secretarySignsProtocols;
            }

            await ef.SaveChangesAsync();

            _lastSavedDeputy = _deputyChairProvided;
            _lastSavedSecretary = _secretaryProvided;
            _lastSavedSecretarySigns = _secretarySignsProtocols;
            _status = "Настройки сохранены";
            _statusCss = "text-success";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Ошибка сохранения настроек СД");
            _status = $"Ошибка сохранения: {ExceptionFlattener.Unwrap(ex)}";
            _statusCss = "text-danger";
        }
    }

    private void CancelOptions()
    {
        _deputyChairProvided = _lastSavedDeputy;
        _secretaryProvided = _lastSavedSecretary;
        _secretarySignsProtocols = _lastSavedSecretarySigns;
        _status = "Изменения отменены";
        _statusCss = "text-muted";
    }
}
