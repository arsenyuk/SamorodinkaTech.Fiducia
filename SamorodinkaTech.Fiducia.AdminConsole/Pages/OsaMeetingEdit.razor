                            </div>
                            <div class="col-md-4">
                                <strong>Протокол:</strong> @(editProtocolSigned ? $"подписан {editProtocolSignedAt:dd.MM.yyyy}" : "не подписан")
                            </div>
                        </div>
                        <div class="row small mt-1">
                            <div class="col-md-4">
                                <strong>Акционеров:</strong> @(editShareholdersCount?.ToString() ?? "—")
