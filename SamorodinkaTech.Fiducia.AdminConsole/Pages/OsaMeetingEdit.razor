            {
                editBoardCompositionApproved = false;
                OnBoardCompositionChanged();
            }
        }
    }

    private async Task EnsureUserIds(IApplicationDbContext ctx, bool validateExisting = false)
    {
        foreach (var row in boardMemberRows)
        {
            // Проверяем, что ранее назначенный UserId действителен (существует в БД)
            if (row.UserId.HasValue)
            {
                if (validateExisting)
                {
                    var exists = await ctx.Users.AnyAsync(u => u.Id == row.UserId.Value);
                    if (!exists)
                    {
                        Logger.LogWarning("UserId {UserId} не найден в БД для строки {Name} — сброс UserId",
                            row.UserId, row.Name);
                        row.UserId = null;
                    }
                }
                if (row.UserId.HasValue)
                    continue;
            }

            if (string.IsNullOrWhiteSpace(row.Email) || string.IsNullOrWhiteSpace(row.Name)) continue;

            // Ищем в change tracker'е (уже добавлен в этом же цикле) или в БД
            var existing = await ctx.Users.FirstOrDefaultAsync(u => u.Email == row.Email.Trim());
            if (existing != null)
            {
                row.UserId = existing.Id;
                continue;
            }

            var nameParts = row.Name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            var candidate = ldapCandidates.FirstOrDefault(c =>
                string.Equals(c.Login, row.Account ?? row.LdapLogin, StringComparison.OrdinalIgnoreCase));
            var newUser = new User
            {
                Id = Guid.NewGuid(),
                LastName = nameParts.Length > 0 ? nameParts[0] : row.Name,
                FirstName = nameParts.Length > 1 ? nameParts[1] : string.Empty,
                MiddleName = nameParts.Length > 2 ? nameParts[2] : null,
                Email = row.Email.Trim(),
                Phone = $"auto-{Guid.NewGuid():N}"[..Math.Min(20, 5 + 32)],
                IsExternal = false,
                IsActive = candidate?.IsActive ?? true,
                AccountExpiresAt = candidate?.AccountExpiresAt,
                LdapCreatedAt = candidate?.LdapCreatedAt,
                CreatedAt = DateTime.UtcNow
            };
            ctx.Users.Add(newUser);
            row.UserId = newUser.Id;
        }
    }

    private async void OnBoardCompositionChanged()
    {
        try
        {
            if (!editBoardCompositionApproved)
            {
                editDeputyChairProvided = false;
                editSecretaryProvided = true;
                editSecretarySignsProtocols = false;
                editTemporaryChairProvided = false;
                editTemporaryChairSelection = "CHARTER_SENIOR";
                boardMemberRows.Clear();
            }
            else if (boardMemberRows.Count == 0)
            {
                // Автозаполнение состава СД
                await using var ctx = await DbFactory.CreateDbContextAsync();

                // Ищем последний состав СД (копируем если есть)
                var lastOsaWithMembers = await ctx.OsaMeetings
                    .Where(x => x.Id != editingMeetingId && x.BoardCompositionApproved)
                    .OrderByDescending(x => x.CreatedAt)
                    .FirstOrDefaultAsync();

                if (lastOsaWithMembers != null)
                {
                    var lastMembers = await ctx.BoardMembers
                        .Where(x => x.OsaMeetingId == lastOsaWithMembers.Id)
                        .Include(x => x.BoardMemberType)
                        .OrderBy(x => x.FullName)
                        .ToListAsync();

                    var lastAppointments = await ctx.BoardMemberAppointments
                        .Where(x => lastMembers.Select(m => m.Id).Contains(x.BoardMemberId) && x.Status.Code == "ACTIVE")
                        .ToListAsync();

                    foreach (var m in lastMembers)
                    {
                        var appt = lastAppointments.FirstOrDefault(a => a.BoardMemberId == m.Id);
                        boardMemberRows.Add(new BoardMemberRow
                        {
                            Name = m.FullName,
                            MemberTypeId = m.BoardMemberTypeId,
                            RoleId = appt?.RoleId ?? memberRoleId,
                            StartedAt = appt?.StartedAt.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd")
                        });
                    }
                }
                else
                {
                    // Новый состав: строки по количеству участников СД (секретарь — дополнительно)
                    var memberCount = editBoardMemberNumber ?? (editBoardMinNumber ?? 3);
                    var membRoleId = memberRoleId;

                    for (int i = 0; i < memberCount; i++)
                    {
                        boardMemberRows.Add(new BoardMemberRow
                        {
                            Name = "",
                            RoleId = membRoleId,
                            StartedAt = DateTime.Today.ToString("yyyy-MM-dd")
                        });
                    }
                    // Секретарь — дополнительный состав, не входит в editBoardMemberNumber
                    if (editSecretaryProvided)
                    {
                        var secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
                        boardMemberRows.Add(new BoardMemberRow
                        {
                            Name = "",
                            RoleId = secRoleId ?? membRoleId,
                            MemberTypeId = staffMemberTypeId,
                            StartedAt = DateTime.Today.ToString("yyyy-MM-dd")
                        });
                    }
                }
                ComputeBoardMemberNumber();
                EnsureBoardMemberCount();
                UpdateGosaCountFromTypes();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ошибка в OnBoardCompositionChanged для ОСА {OsaMeetingId}", editingMeetingId);
        }
    }

