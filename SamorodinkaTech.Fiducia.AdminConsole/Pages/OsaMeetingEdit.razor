@page "/admin/osa-meetings/{id:guid}"
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@using SamorodinkaTech.Fiducia.Domain.Entities
@using SamorodinkaTech.Fiducia.Domain.Interfaces
@using SamorodinkaTech.Fiducia.Domain.Models.Ldap
@inject IDbContextFactory<SamorodinkaTech.Fiducia.Infrastructure.Persistence.FiduciaDbContext> DbFactory
@inject SamorodinkaTech.Fiducia.Domain.Interfaces.ILegalEntityGosaIntervalService GosaSvc
@inject SamorodinkaTech.Fiducia.Domain.Interfaces.IFileStorage FileStorage
@inject ILogger<OsaMeetings> Logger
@inject NavigationManager Nav
@inject IConfiguration Config
@inject IServiceProvider ServiceProvider
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SYS_ADMIN")]

<h3>
    @{
        var headerTitle = editIsGosa ? BuildGosaTitle(editGosaStart) : editTitle;
    }
    @if (!string.IsNullOrEmpty(headerTitle))
    {
        <span>@headerTitle</span>
    }
    else
    {
        <span>Редактирование ОСА — @osaForms.FirstOrDefault(f => f.Id == editingFormId)?.Name</span>
    }
</h3>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span></span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => BackToList()">← К списку</button>
            </div>
    <div class="card mb-3">
        <div class="card-body">

            <ul class="nav nav-tabs mb-3">
                @{
                    // Вычисляем цепочку достижимости: вкладка idx достижима, если все предыдущие прошли валидацию
                    var stepReachable = new bool[wizardSteps.Length];
                    stepReachable[0] = true;
                    for (int i = 1; i < wizardSteps.Length; i++)
                        stepReachable[i] = stepReachable[i - 1] && IsStepValid(i - 1);
                }
                @foreach (var step in wizardSteps)
                {
                    var idx = Array.IndexOf(wizardSteps, step);
                    var active = idx == currentStep;
                    var done = idx < currentStep;
                    var reachable = stepReachable[idx];
                    var tabClass = isFinalized ? (active ? "active fw-bold text-success" : "text-success")
                        : active ? (CanAdvance ? "active fw-bold text-success" : "active fw-bold text-warning")
                        : (done || reachable) ? "text-success"
                        : "text-muted";
                    var tabClickable = idx != currentStep;
                    var tabDisabled = !tabClickable && idx != currentStep;
                    <li class="nav-item">
                        <button type="button"
                                class="nav-link @tabClass"
                                style="cursor:@(tabClickable ? "pointer" : "default")"
                                disabled="@tabDisabled"
                                @onclick="() => GoToStep(idx)">
                            @if (idx < currentStep) { <span class="text-success me-1">✓</span> }
                            else if (reachable && idx > currentStep) { <span class="text-success me-1">→</span> }
                            @step
                        </button>
                    </li>
                }
            </ul>

            @if (currentStep == 0)
            {
            <div class="mb-3">
                <label class="form-label">Название</label>
                <input class="form-control"
                       value="@(editIsGosa ? BuildGosaTitle(editGosaStart) : editTitle)"
                       @onchange="@(e => { if (!editIsGosa) editTitle = e.Value?.ToString() ?? string.Empty; })"
                       disabled="@(isFinalized || editIsGosa)" />
                @if (editIsGosa)
                {
                    <div class="text-muted small mt-1">Заполняется автоматически по шаблону из настроек</div>
                }
            </div>

            @if (editIsGosa)
            {
                @* Год проведения ГОСА — скрытое поле, вычисляется из даты начала *@
                <input type="hidden" @bind="editGosaYear" />
                @if (editGosaYear.HasValue && editGosaYear.Value < DateTime.Now.Year - 1)
                {
                    <div class="text-warning small mt-1">Год в прошлом</div>
                }
            }

            @if (editIsGosa && !editAbsenteeVoting)
            {
                <div class="mb-3">
                    <div class="row g-3 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Начало ОСА</label>
                            <InputDate @bind-Value="editGosaStart" class="form-control" disabled="@isFinalized"
                                       @bind-Value:after="() => { if (editIsGosa) editGosaYear = editGosaStart.Year; }" />
                        </div>
                        <div class="col-auto">
                            <label class="form-label">Завершение ОСА</label>
                            <InputDate @bind-Value="editGosaEnd" class="form-control" disabled="@isFinalized" />
                        </div>
                        <div class="col-auto">
                            @if (!string.IsNullOrEmpty(gosaError))
                            {
                                <span class="text-danger small">@gosaError</span>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (!editIsGosa)
            {
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editAbsentee" @bind="editAbsenteeVoting" disabled="@isFinalized" />
                    <label class="form-check-label" for="editAbsentee">Заочное голосование</label>
                    @if (editAbsenteeVoting)
                    {
                        <span class="ms-3">
                            <label class="form-label small mb-0">Дата окончания приема бюллетеней</label>
                            <InputDate @bind-Value="editBallotDeadline" class="form-control form-control-sm d-inline-block ms-2" style="width:180px" disabled="@isFinalized" />
                        </span>
                    }
                </div>
            }
            }

            @if (currentStep == 1)
            {
            @if (editHasBoard)
            {
            <div class="mb-3">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editShareholdersList" @bind="editShareholdersListReceived" disabled="@isFinalized" />
                    <label class="form-check-label" for="editShareholdersList">Список акционеров получен</label>
                </div>
                <div class="row g-3 align-items-end mb-2">
                    <div class="col-12 col-md-4 col-lg-3 text-md-end text-muted">
                        <label class="form-label mb-0">Количество акционеров</label>
                    </div>
                    <div class="col-12 col-md-4 col-lg-4 d-flex justify-content-md-center">
                        <input class="form-control" style="max-width:110px" type="number" min="0" step="1" @bind="editShareholdersCount" disabled="@(isFinalized || !editShareholdersListReceived)" />
                    </div>
                    <div class="col-12 col-md-4 col-lg-5">
                        <div class="text-danger small">
                            @if (editShareholdersCount.HasValue && editShareholdersCount.Value <= 0)
                            {
                                <span>Укажите количество акционеров</span>
                            }
                            else if (!editIsPao && editShareholdersCount.HasValue && editShareholdersCount.Value > 50)
                            {
                                <span>Максимум 50 акционеров</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="row g-3 align-items-end mb-2">
                    <div class="col-12 col-md-4 col-lg-3 text-md-end text-muted">
                        <label class="form-label mb-0">Количество участников СД</label>
                    </div>
                    <div class="col-12 col-md-4 col-lg-4 d-flex justify-content-md-center">
                        <input class="form-control" style="max-width:110px" type="number" min="0" value="@editBoardMemberNumber" @oninput="OnBoardMemberNumberInput" disabled="@(isFinalized || !editShareholdersListReceived)" />
                    </div>
                    <div class="col-12 col-md-4 col-lg-5">
                        <div class="small">
                            @if (editBoardMemberNumber.HasValue && editBoardMinNumber.HasValue && editBoardMemberNumber.Value < editBoardMinNumber.Value)
                            {
                                <span class="text-danger">Минимум: @editBoardMinNumber</span>
                            }
                            else if (editBoardMinNumber.HasValue)
                            {
                                <span class="text-muted">Минимум: @editBoardMinNumber</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            }
            }

            @if (currentStep == 2)
            {
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="editOsaHeld" @bind="editOsaHeld" @bind:after="OnOsaHeldChanged" disabled="@isFinalized" />
                <label class="form-check-label" for="editOsaHeld">ОСА проведено</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="editProtocolSigned" @bind="editProtocolSigned" disabled="@(isFinalized || !editOsaHeld)" />
                <label class="form-check-label" for="editProtocolSigned">Протокол подписан</label>
                @if (editProtocolSigned)
                {
                    <span class="ms-3">
                        <label class="form-label small mb-0">Дата подписания протокола</label>
                        <InputDate @bind-Value="editProtocolSignedAt" class="form-control form-control-sm d-inline-block ms-2" style="width:180px" disabled="@isFinalized" />
                    </span>
                }
            </div>
            @if (!IsProtocolStepValid())
            {
                <div class="text-warning small mt-2">
                    @{
                        var protoError = GetProtocolValidationError();
                    }
                    ⚠ @protoError
                </div>
            }
            }

            @if (currentStep == 3)
            {
            <div class="mb-3">
                @if (editHasBoard && editProtocolSigned)
                {
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="editBoardMandatory" checked="@editBoardMandatory" disabled />
                        <label class="form-check-label" for="editBoardMandatory">
                            Совет директоров обязателен
                        </label>
                    </div>
                    @if (!editBoardMandatory)
                    {
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="editBoardApproved" @bind="editBoardApproved" disabled="@isFinalized"
                               @bind:after="OnBoardApprovedChanged" />
                        <label class="form-check-label" for="editBoardApproved">Совет директоров утверждён</label>
                    </div>
                    }
                    @if (editBoardMandatory || editBoardApproved)
                    {
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="editBoardComposition" checked="@editBoardCompositionApproved" disabled />
                        <label class="form-check-label" for="editBoardComposition">Состав СД утверждён</label>
                    </div>
                    }
                </div>
                @if (!editIsGosa)
                {
                <div class="text-muted small mb-2">
                    ℹ️ Для ВОСА: если решения по изменению состава СД не было, флаг «Состав СД утверждён» устанавливать не нужно.
                </div>
                }
                }

                @if (editBoardMandatory || editBoardCompositionApproved)
                {
                <div class="fw-bold mb-2">Штатный состав СД</div>

                <div class="row">
                    <div class="col-md-5 pe-3 border-end">

                <div class="mb-2 d-flex align-items-center gap-2">
                    <input class="form-check-input" type="checkbox" id="editExecDirectors"
                           @bind="editExecDirectors"
                           @bind:after="() => { if (editExecDirectors && !editExecDirectorsCount.HasValue) editExecDirectorsCount = 1; if (!editExecDirectors) editExecDirectorsCount = null; ComputeBoardMemberNumber(); EnsureBoardMemberCount(); UpdateGosaCountFromTypes(); }"
                           disabled="@isFinalized" />
                    <label class="form-check-label flex-grow-1" for="editExecDirectors">Исполнительный директор</label>
                    <input class="form-control form-control-sm @(editExecDirectors ? "" : "invisible")" style="width:80px"
                           type="number" min="1" @bind="editExecDirectorsCount" @bind:after="() => { ComputeBoardMemberNumber(); EnsureBoardMemberCount(); UpdateGosaCountFromTypes(); }" disabled="@isFinalized" />
                </div>
                <div class="mb-2 d-flex align-items-center gap-2">
                    <input class="form-check-input" type="checkbox" id="editNonExecDirectors"
                           @bind="editNonExecDirectors"
                           @bind:after="() => { if (editNonExecDirectors && !editNonExecDirectorsCount.HasValue) editNonExecDirectorsCount = 1; if (!editNonExecDirectors) editNonExecDirectorsCount = null; ComputeBoardMemberNumber(); EnsureBoardMemberCount(); UpdateGosaCountFromTypes(); }"
                           disabled="@isFinalized" />
                    <label class="form-check-label flex-grow-1" for="editNonExecDirectors">Внешний директор</label>
                    <input class="form-control form-control-sm @(editNonExecDirectors ? "" : "invisible")" style="width:80px"
                           type="number" min="1" @bind="editNonExecDirectorsCount" @bind:after="() => { ComputeBoardMemberNumber(); EnsureBoardMemberCount(); UpdateGosaCountFromTypes(); }" disabled="@isFinalized" />
                </div>
                <div class="d-flex align-items-center gap-2">
                    <input class="form-check-input" type="checkbox" id="editIndepDirectors"
                           @bind="editIndepDirectors"
                           @bind:after="() => { if (editIndepDirectors && !editIndepDirectorsCount.HasValue) editIndepDirectorsCount = 1; if (!editIndepDirectors) editIndepDirectorsCount = null; ComputeBoardMemberNumber(); EnsureBoardMemberCount(); UpdateGosaCountFromTypes(); }"
                           disabled="@isFinalized" />
                    <label class="form-check-label flex-grow-1" for="editIndepDirectors">Независимый директор</label>
                    <input class="form-control form-control-sm @(editIndepDirectors ? "" : "invisible")" style="width:80px"
                           type="number" min="1" @bind="editIndepDirectorsCount" @bind:after="() => { ComputeBoardMemberNumber(); EnsureBoardMemberCount(); UpdateGosaCountFromTypes(); }" disabled="@isFinalized" />
                </div>

                    </div>
                    <div class="col-md-7 ps-3">

                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editDeputyChair" @bind="editDeputyChairProvided" disabled="@isFinalized" />
                    <label class="form-check-label" for="editDeputyChair">Предусмотрен заместитель председателя</label>
                </div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <input class="form-check-input" type="checkbox" id="editTempChair" @bind="editTemporaryChairProvided" @bind:after="OnTempChairChanged" disabled="@isFinalized" />
                    <label class="form-check-label" for="editTempChair">Предусмотрен временный председательствующий</label>
                    <select class="form-select form-select-sm @(editTemporaryChairProvided ? "" : "invisible")" style="width:280px"
                            value="@editTemporaryChairSelection"
                            @onchange="HandleTempChairSelection"
                            disabled="@isFinalized">
                        <option value="GMS_DECISION">По решению ОСА</option>
                        <option value="CHARTER_SENIOR">По уставу — старший по возрасту</option>
                        <option value="BOARD_ELECTION">По решению СД</option>
                    </select>
                </div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="editSecretary" @bind="editSecretaryProvided" @bind:after="OnSecretaryChanged" disabled="@isFinalized" />
                        <label class="form-check-label" for="editSecretary">Предусмотрен секретарь СД</label>
                    </div>
                    <div class="form-check mb-0 @(editSecretaryProvided ? "" : "invisible")">
                        <input class="form-check-input" type="checkbox" id="editSecretarySigns" @bind="editSecretarySignsProtocols" disabled="@isFinalized" />
                        <label class="form-check-label" for="editSecretarySigns">Секретарь СД подписывает протоколы</label>
                    </div>
                </div>

                    </div>
                </div>
                }
            </div>

            @if (editBoardCompositionApproved)
            {
                @if (editIsPao && (!editIndepDirectors || (editIndepDirectorsCount ?? 0) == 0))
                {
                    <div class="alert alert-warning py-2 mb-2 small">
                        ⚠️ Для ПАО обязателен комитет по аудиту (<a href="/admin/board-law/64">п. 3 ст. 64 208-ФЗ</a>). В составе СД отсутствуют независимые директора.
                    </div>
                }

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="fw-bold">Готовимся к первому заседанию @(editGosaYear.HasValue ? $"(Совет директоров {editGosaYear.Value})" : "")</span>
                    </div>
                    <div class="text-muted small mb-2">Заполните все разрешённые поля для каждого члена СД (ФИО, учётная запись, эл. почта).</div>
                    @if (!string.IsNullOrEmpty(ldapDuplicateWarning))
                    {
                        <div class="alert alert-warning py-2 mb-2 small">⚠️ @ldapDuplicateWarning</div>
                    }
                    @* ДИАГНОСТИКА — убрать после отладки *@
                    <div class="text-muted small mb-1" style="font-family:monospace;font-size:11px">
                        editHasBoard=@editHasBoard | editBoardMandatory=@editBoardMandatory | editBoardApproved=@editBoardApproved | editBoardCompositionApproved=@editBoardCompositionApproved
                        | fieldsValid=@AreBoardMemberFieldsValid() | failReason=@GetBoardValidationFailReason() | ldapWarning=@(ldapDuplicateWarning != null)
                        | IsStepValid(3)=@IsStepValid(3) | boardRoles.Count=@boardRoles.Count
                        | memberRoleId=@(memberRoleId?.ToString() ?? "null") | rows=@boardMemberRows.Count
                        | editBoardMemberNumber=@editBoardMemberNumber | secRoleId=@(boardRoles.FirstOrDefault(r=>r.Code=="SECRETARY")?.Id.ToString()??"null")
                        | tempChairProvided=@editTemporaryChairProvided | tempChairSel=@editTemporaryChairSelection | tempChairRoleId=@(tempChairRoleId?.ToString()??"null")
                        | execDir=@(editExecDirectors?$"✓{editExecDirectorsCount}":"✗") | nonExec=@(editNonExecDirectors?$"✓{editNonExecDirectorsCount}":"✗") | indep=@(editIndepDirectors?$"✓{editIndepDirectorsCount}":"✗")
                        <br/>
                        @foreach (var r in boardMemberRows)
                        {
                            var roleCode = boardRoles.FirstOrDefault(x => x.Id == r.RoleId)?.Code ?? "null";
                            var nameS = string.IsNullOrWhiteSpace(r.Name) ? "(пусто)" : r.Name[..Math.Min(r.Name.Length, 15)];
                            var typeCode = memberTypes.FirstOrDefault(x => x.Id == r.MemberTypeId)?.Code ?? "null";
                            @: | [@roleCode] @nameS acc=@(r.Account?[..Math.Min((r.Account??"").Length,10)]??"null") ldap=@(r.LdapLogin?[..Math.Min((r.LdapLogin??"").Length,10)]??"null") type=@typeCode
                        }
                    </div>
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>ФИО</th>
                                <th>Тип участника</th>
                                <th>Роль в СД</th>
                                <th>Учётная запись</th>
                                <th>Эл. почта</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
                            }
                            @for (int i = 0; i < boardMemberRows.Count; i++)
                            {
                                var row = boardMemberRows[i];
                                var isSecretary = secRoleId.HasValue && row.RoleId == secRoleId;
                                var isMember = memberRoleId.HasValue && row.RoleId == memberRoleId;
                                var nameEmpty = !isSecretary && string.IsNullOrWhiteSpace(row.Name);
                                var typeEmpty = !isSecretary && !isMember && !row.MemberTypeId.HasValue;
                                var nameClass = (ldapEnabled && !isSecretary && !isFinalized
                                    ? "form-select form-select-sm"
                                    : "form-control form-control-sm") + (nameEmpty ? " border-danger" : "");
                                var typeClass = "form-select form-select-sm" + (typeEmpty ? " border-danger" : "");
                                <tr>
                                    @if (ldapEnabled && ldapSvc != null && !isSecretary && !isFinalized)
                                    {
                                        <td>
                                            <select class="@nameClass"
                                                    value="@row.LdapLogin"
                                                    @onchange="e => OnLdapCandidateSelected(row, e)">
                                                <option value="">—</option>
                                                @foreach (var c in ldapCandidates)
                                                {
                                                    <option value="@c.Login">@c.FullName</option>
                                                }
                                            </select>
                                        </td>
                                    }
                                    else
                                    {
                                        <td><input class="@nameClass" @bind="row.Name" disabled="@(isSecretary || isFinalized)" /></td>
                                    }
                                    <td>
                                        <select class="@typeClass"
                                                value="@(row.MemberTypeId?.ToString())"
                                                disabled="@(isSecretary || isMember || isFinalized)"
                                                @onchange="e => OnMemberTypeChanged(row, e)">
                                            <option value="">—</option>
                                            @foreach (var t in memberTypes.Where(t => isSecretary || t.Code != "STAFF"))
                                            {
                                                <option value="@t.Id">@t.Name</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                value="@(row.RoleId?.ToString())"
                                                disabled>
                                            <option value="">—</option>
                                            @foreach (var r in boardRoles)
                                            {
                                                <option value="@r.Id">@r.Name</option>
                                            }
                                        </select>
                                    </td>
                                    @if (ldapEnabled && ldapSvc != null && !isSecretary && !isFinalized)
                                    {
                                        <td>
                                            <select class="form-select form-select-sm"
                                                    value="@row.LdapLogin"
                                                    @onchange="e => OnLdapCandidateSelected(row, e)">
                                                <option value="">—</option>
                                                @foreach (var c in ldapCandidates)
                                                {
                                                    <option value="@c.Login">@c.Login</option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm"
                                                    value="@row.LdapLogin"
                                                    @onchange="e => OnLdapCandidateSelected(row, e)">
                                                <option value="">—</option>
                                                @foreach (var c in ldapCandidates)
                                                {
                                                    <option value="@c.Login">@c.Email</option>
                                                }
                                            </select>
                                        </td>
                                    }
                                    else
                                    {
                                        <td><input class="form-control form-control-sm" @bind="row.Account" disabled="@(isSecretary || isFinalized)" /></td>
                                        <td><input class="form-control form-control-sm" @bind="row.Email" disabled="@(isSecretary || isFinalized)" /></td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            }

            @if (currentStep == 4)
            {
            @* Файлы *@
            <fieldset class="border rounded p-3 mb-3">
                <legend class="float-none w-auto px-2 mb-0">Файлы</legend>
                @if (editIsGosa && !editHasBoard)
                {
                    <div class="alert alert-info py-2 mb-2 small">
                        ℹ️ СД отсутствует (функции СД выполняет ОСА по уставу, <a href="/admin/board-law/64">п. 1 ст. 64 Закона об АО</a>) —
                        прикладывание файлов необязательно.
                    </div>
                }
                else if (editIsGosa)
                {
                    <div class="alert alert-warning py-2 mb-2 small">
                        ⚠️ Для ГОСА обязателен юридически значимый документ (ЮЗД) с информацией о составе СД.
                    </div>
                }
                @if (meetingFiles.Any())
                {
                    <table class="table table-sm">
                        <thead><tr><th>Тип</th><th>Наименование</th><th>Имя файла</th><th>Размер</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var mf in meetingFiles)
                        {
                            <tr>
                                <td><span class="badge @FileTypeBadge(mf.FileType)">@FileTypeLabel(mf.FileType)</span></td>
                                <td>@(mf.DisplayName ?? "—")</td>
                                <td>@mf.FileName</td>
                                <td>@FormatSize(mf.SizeBytes)</td>
                                <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFile(mf.Id)" disabled="@isFinalized">Удалить</button></td>
                            </tr>
