    private async Task SaveEdit()
    {
        if (!editingMeetingId.HasValue) return;
        saveError = null;
        saveSuccess = null;
        gosaError = null;

        Logger.LogDebug("Серверная валидация ОСА редактирование {OsaMeetingId}", editingMeetingId.Value);

        // Серверная валидация ОСА (BDR‑008) — только если СД существует
        if (editHasBoard)
        {
            var validationModel = new SamorodinkaTech.Fiducia.Domain.Validation.OsaMeetingValidationModel
            {
                ShareholdersCount = editShareholdersCount,
                OkopfCode = editOkopfCode,
                BoardMinNumber = editBoardMinNumber,
                BoardMemberNumber = editBoardMemberNumber,
                HasGosaInterval = editIsGosa && !editAbsenteeVoting,
                IsAbsentee = editAbsenteeVoting,
                GosaYear = editGosaYear,
                ExecutiveDirectorsParticipate = editExecDirectors,
                ExecutiveDirectorsCount = editExecDirectorsCount,
                NonExecutiveDirectorsParticipate = editNonExecDirectors,
                NonExecutiveDirectorsCount = editNonExecDirectorsCount,
                IndependentDirectorsParticipate = editIndepDirectors,
                IndependentDirectorsCount = editIndepDirectorsCount
            };
            var validation = SamorodinkaTech.Fiducia.Domain.Validation.OsaMeetingValidator.Validate(validationModel);
            if (!validation.IsValid)
            {
                Logger.LogWarning("Валидация не пройдена для ОСА {OsaMeetingId}: {Errors}",
                    editingMeetingId.Value, string.Join("; ", validation.Errors));
                saveError = string.Join(" ", validation.Errors);
                return;
            }
        }

        if (editIsGosa)
        {
            var (defStart, defEnd) = GosaSvc.GetDefaultWindow();
            if (editGosaStart < defStart || editGosaEnd > defEnd)
            {
                gosaError = $"Даты должны быть в пределах {defStart:dd.MM}–{defEnd:dd.MM}";
                Logger.LogWarning("Валидация не пройдена для ОСА {OsaMeetingId}: {Errors}", editingMeetingId.Value, gosaError);
                return;
            }
            if (editGosaEnd < editGosaStart)
            {
                gosaError = "Завершение ОСА не может быть раньше начала ОСА";
                Logger.LogWarning("Валидация не пройдена для ОСА {OsaMeetingId}: {Errors}", editingMeetingId.Value, gosaError);
                return;
            }
        }

        if (editProtocolSigned && editProtocolSignedAt.HasValue && editProtocolSignedAt > DateTime.Now)
        {
            saveError = "Дата подписания протокола не может быть в будущем";
            return;
        }

        if (editProtocolSigned && editProtocolSignedAt.HasValue)
        {
            var referenceDate = editAbsenteeVoting && editBallotDeadline.HasValue
                ? editBallotDeadline.Value
                : (editIsGosa ? editGosaEnd.ToDateTime(TimeOnly.MinValue) : DateTime.MinValue);

            if (referenceDate != DateTime.MinValue)
            {
                var signedAt = (DateTime)editProtocolSignedAt;
                var deadline = referenceDate.AddDays(3);
                if (signedAt < referenceDate)
                {
                    saveError = "Дата подписания протокола не может быть раньше даты завершения ОСА";
                    return;
                }
                if (signedAt > deadline)
                {
                    saveError = $"Дата подписания протокола не может быть позднее {deadline:dd.MM.yyyy} (3 дня после завершения ОСА)";
                    return;
                }
            }
        }

        // Серверная валидация полей членов СД с ролью «Член СД»
        if (editBoardCompositionApproved && editHasBoard)
        {
            // Количество строк (без секретаря и временного председательствующего) должно совпадать с заявленным и быть не меньше минимума
            var secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
            var nonSecretaryCount = boardMemberRows.Count(r => r.RoleId != secRoleId && r.RoleId != tempChairRoleId);
            if (editBoardMemberNumber.HasValue && nonSecretaryCount != editBoardMemberNumber.Value)
            {
                saveError = $"Количество членов СД в списке ({nonSecretaryCount}) не совпадает с заявленным ({editBoardMemberNumber})";
                Logger.LogWarning("Валидация не пройдена для состава СД {OsaMeetingId}: строк (без секретаря) {Actual} ≠ заявлено {Expected}",
                    editingMeetingId, nonSecretaryCount, editBoardMemberNumber);
                return;
            }
            if (editBoardMinNumber.HasValue && nonSecretaryCount < editBoardMinNumber.Value)
            {
                saveError = $"Количество членов СД в списке ({nonSecretaryCount}) меньше законодательного минимума ({editBoardMinNumber})";
                Logger.LogWarning("Валидация не пройдена для состава СД {OsaMeetingId}: строк (без секретаря) {Actual} < минимум {Min}",
                    editingMeetingId, nonSecretaryCount, editBoardMinNumber);
                return;
            }

            // Все строки (кроме секретаря и временного председательствующего) должны быть заполнены
            var fillRows = boardMemberRows
                .Where(r => r.RoleId != secRoleId && r.RoleId != tempChairRoleId)
                .ToList();
            foreach (var row in fillRows)
            {
                if (string.IsNullOrWhiteSpace(row.Name)
                    || !row.MemberTypeId.HasValue)
                {
                    saveError = "Для членов СД должны быть заполнены все поля (ФИО, тип участника, дата начала полномочий)";
                    Logger.LogWarning("Валидация не пройдена для состава СД {OsaMeetingId}: незаполненные поля у члена {Name}",
                        editingMeetingId, row.Name);
                    return;
                }
            }

            // Дублирование ФИО среди членов СД недопустимо
            var dupNames = fillRows
                .Where(r => !string.IsNullOrWhiteSpace(r.Name))
                .GroupBy(r => r.Name.Trim())
                .Where(g => g.Count() > 1)
                .Select(g => g.Key)
                .ToList();
            if (dupNames.Count > 0)
            {
                saveError = $"Дублирование ФИО среди членов СД: «{string.Join("», «", dupNames)}»";
                Logger.LogWarning("Валидация не пройдена для состава СД {OsaMeetingId}: дубли ФИО: {Names}",
                    editingMeetingId, string.Join(", ", dupNames));
                return;
            }

            // Секретарь обязан иметь тип «Штатный сотрудник», остальные — не могут
            if (secRoleId.HasValue && staffMemberTypeId.HasValue)
            {
                foreach (var row in boardMemberRows)
                {
                    var isSec = row.RoleId == secRoleId;
                    var isStaff = row.MemberTypeId == staffMemberTypeId;
                    if (isSec && !isStaff)
                    {
                        saveError = "Секретарь СД должен иметь тип «Штатный сотрудник»";
                        Logger.LogWarning("Валидация не пройдена: секретарь без STAFF в ОСА {OsaMeetingId}", editingMeetingId);
                        return;
                    }
                    if (!isSec && isStaff)
                    {
                        saveError = "Тип «Штатный сотрудник» разрешён только для секретаря СД";
                        Logger.LogWarning("Валидация не пройдена: не-секретарь со STAFF в ОСА {OsaMeetingId} ({Name})", editingMeetingId, row.Name);
                        return;
                    }
                }
            }

            // Временный председательствующий — 0 или 1
            var tcRoleId = tempChairRoleId;
            if (tcRoleId.HasValue)
            {
                var tcCount = boardMemberRows.Count(r => r.RoleId == tcRoleId);
                if (tcCount > 1)
                {
                    saveError = "Временный председательствующий может быть только один";
                    Logger.LogWarning("Валидация не пройдена: TEMP_CHAIR = {Count} в ОСА {OsaMeetingId}", tcCount, editingMeetingId);
                    return;
                }

                // Временный председательствующий должен быть заполнен (ФИО, тип участника)
                if (editTemporaryChairProvided && editTemporaryChairSelection == "GMS_DECISION")
                {
                    var tcRow = boardMemberRows.FirstOrDefault(r => r.RoleId == tcRoleId.Value);
                    if (tcRow == null
                        || string.IsNullOrWhiteSpace(tcRow.Name)
                        || !tcRow.MemberTypeId.HasValue)
                    {
                        saveError = "Временный председательствующий не заполнен (ФИО, тип участника)";
                        Logger.LogWarning("Валидация не пройдена: TEMP_CHAIR не заполнен в ОСА {OsaMeetingId}", editingMeetingId);
                        return;
                    }
                }
            }
        }

        if (editIsGosa && !meetingFiles.Any())
        {
            saveError = "Для ГОСА необходимо прикрепить хотя бы один юридически значимый документ (ЮЗД) с информацией о составе СД";
            return;
        }

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var m = await ctx.OsaMeetings.FirstOrDefaultAsync(x => x.Id == editingMeetingId.Value);
            if (m is null) return;

            if (editIsGosa)
            {
                // Проверка уникальности года ГОСА (исключая текущую запись)
                if (editGosaYear.HasValue && m.GosaYear != editGosaYear)
                {
                    var duplicate = await ctx.OsaMeetings
                        .AnyAsync(x => x.Id != editingMeetingId.Value && x.GosaYear == editGosaYear.Value);
                    if (duplicate)
                    {
                        saveError = $"ГОСА за {editGosaYear.Value} год уже существует. Нельзя создать более одного ГОСА в году.";
                        Logger.LogWarning("Валидация не пройдена для ОСА {OsaMeetingId}: {Errors}", editingMeetingId.Value, saveError);
                        return;
                    }
                }

                m.GosaWindowStart = editGosaStart;
                m.GosaWindowEnd = editGosaEnd;
                m.GosaYear = editGosaYear;
            }

            m.Title = editIsGosa ? BuildGosaTitle(editGosaStart) : (string.IsNullOrWhiteSpace(editTitle) ? null : editTitle.Trim());
            m.ShareholdersCount = editHasBoard ? editShareholdersCount : null;
            m.BoardMemberNumber = editHasBoard ? editBoardMemberNumber : null;
            m.ExecutiveDirectorsParticipate = editExecDirectors;
            m.ExecutiveDirectorsCount = editExecDirectors ? editExecDirectorsCount : null;
            m.NonExecutiveDirectorsParticipate = editNonExecDirectors;
            m.NonExecutiveDirectorsCount = editNonExecDirectors ? editNonExecDirectorsCount : null;
            m.IndependentDirectorsParticipate = editIndepDirectors;
            m.IndependentDirectorsCount = editIndepDirectors ? editIndepDirectorsCount : null;
            m.ShareholdersListReceived = editShareholdersListReceived;
            m.AbsenteeVoting = editAbsenteeVoting;
            m.BallotDeadline = editAbsenteeVoting && editBallotDeadline.HasValue
                ? ((DateTime)editBallotDeadline).ToUniversalTime() : null;
            m.OsaHeld = editOsaHeld;
            m.ProtocolSigned = editProtocolSigned && editOsaHeld;
            m.DeputyChairProvided = editDeputyChairProvided;
            m.SecretaryProvided = editSecretaryProvided;
            m.SecretarySignsProtocols = editSecretaryProvided && editSecretarySignsProtocols;
            m.TemporaryChairProvided = editTemporaryChairProvided;
            m.TemporaryChairSelection = editTemporaryChairProvided ? editTemporaryChairSelection : null;
            m.BoardCompositionApproved = editBoardCompositionApproved;
            m.BoardMandatory = editBoardMandatory;
            m.BoardApproved = editBoardApproved;
            m.ProtocolSignedAt = editProtocolSigned && editProtocolSignedAt.HasValue
                ? ((DateTime)editProtocolSignedAt).ToUniversalTime() : null;

            // Привязываем строки без UserId к справочнику пользователей (LDAP)
            await EnsureUserIds(ctx, validateExisting: true);

            // Создаём/обновляем запись Совета директоров
            var board = await ctx.BoardsOfDirectors.FirstOrDefaultAsync(x => x.OsaMeetingId == editingMeetingId.Value);
            if (board == null)
            {
                var draftStatusId = boardOfDirectorsStatuses.FirstOrDefault(s => s.Code == "DRAFT")?.Id ?? Guid.Empty;
                board = new SamorodinkaTech.Fiducia.Domain.Entities.BoardOfDirectors
                {
                    Id = Guid.NewGuid(),
                    OsaMeetingId = editingMeetingId.Value,
                    GosaYear = editGosaYear,
                    StatusId = draftStatusId
                };
                ctx.BoardsOfDirectors.Add(board);
            }
            else
            {
                board.GosaYear = editGosaYear;
            }
            editBoardOfDirectorsId = board.Id;

            // Обновляем состав СД: удаляем старых, создаём новых
            var oldMembers = await ctx.BoardMembers.Where(x => x.OsaMeetingId == editingMeetingId.Value).ToListAsync();
            var oldMemberIds = oldMembers.Select(x => x.Id).ToList();
            var oldAppointments = await ctx.BoardMemberAppointments.Where(x => oldMemberIds.Contains(x.BoardMemberId)).ToListAsync();
            ctx.BoardMemberAppointments.RemoveRange(oldAppointments);
            ctx.BoardMembers.RemoveRange(oldMembers);
            var _secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
            var _tcRoleId = tempChairRoleId;
            foreach (var row in boardMemberRows.Where(x => !string.IsNullOrWhiteSpace(x.Name) || x.RoleId == _secRoleId || x.RoleId == _tcRoleId))
            {
                var member = new BoardMember
                {
                    Id = Guid.NewGuid(),
                    OsaMeetingId = editingMeetingId.Value,
                    BoardOfDirectorsId = editBoardOfDirectorsId,
                    FullName = row.Name.Trim(),
                    BoardMemberTypeId = row.MemberTypeId,
                    Account = string.IsNullOrWhiteSpace(row.Account) ? null : row.Account.Trim(),
                    Email = string.IsNullOrWhiteSpace(row.Email) ? null : row.Email.Trim(),
                    UserId = row.UserId
                };
                ctx.BoardMembers.Add(member);

                if (row.RoleId.HasValue && row.StartedAt is not null && DateOnly.TryParse(row.StartedAt, out var startedAt))
                {
                    ctx.BoardMemberAppointments.Add(new BoardMemberAppointment
                    {
                        Id = Guid.NewGuid(),
                        BoardMemberId = member.Id,
                        RoleId = row.RoleId.Value,
                        RoleCode = boardRoles.FirstOrDefault(r => r.Id == row.RoleId.Value)?.Code ?? "",
                        StartedAt = startedAt,
                        StatusId = appointmentStatuses.FirstOrDefault(s => s.Code == "DRAFT")?.Id ?? Guid.Empty
                    });
                }
            }

            await ctx.SaveChangesAsync();
            saveSuccess = "Изменения сохранены.";
            await LoadData();
        }
        catch (Exception ex)
        {
            saveError = ExceptionFlattener.Unwrap(ex);
        }
    }

