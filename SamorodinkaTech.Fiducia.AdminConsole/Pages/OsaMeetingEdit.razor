    private async Task OpenEdit(Guid meetingId)
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var m = await ctx.OsaMeetings.FirstOrDefaultAsync(x => x.Id == meetingId);
        if (m is null) return;

        editingMeetingId = m.Id;
        editingFormId = m.OsaFormId;
        isFinalized = m.Status == "APPROVED";
        finalizedAt = m.FinalizedAt?.ToLocalTime();
        currentStep = 0;
        editIsGosa = m.GosaWindowStart.HasValue;
        editGosaStart = m.GosaWindowStart ?? new DateOnly(DateTime.UtcNow.Year, 3, 1);
        editTitle = m.Title ?? (editIsGosa ? BuildGosaTitle(editGosaStart) : string.Empty);
        editGosaEnd = m.GosaWindowEnd ?? new DateOnly(DateTime.UtcNow.Year, 6, 30);
        editGosaYear = m.GosaYear ?? (editIsGosa ? DateTime.UtcNow.Year : null);
        editGosaEnd = m.GosaWindowEnd ?? new DateOnly(DateTime.UtcNow.Year, 6, 30);
        editShareholdersCount = m.ShareholdersCount;
        editBoardMemberNumber = m.BoardMemberNumber;
        editExecDirectors = m.ExecutiveDirectorsParticipate;
        editExecDirectorsCount = m.ExecutiveDirectorsCount ?? (m.ExecutiveDirectorsParticipate ? 1 : null);
        editNonExecDirectors = m.NonExecutiveDirectorsParticipate;
        editNonExecDirectorsCount = m.NonExecutiveDirectorsCount ?? (m.NonExecutiveDirectorsParticipate ? 1 : null);
        editIndepDirectors = m.IndependentDirectorsParticipate;
        editIndepDirectorsCount = m.IndependentDirectorsCount ?? (m.IndependentDirectorsParticipate ? 1 : null);
        editShareholdersListReceived = m.ShareholdersListReceived;
        editAbsenteeVoting = m.AbsenteeVoting;
        editBallotDeadline = m.BallotDeadline?.ToLocalTime();
        editOsaHeld = m.OsaHeld;
        editProtocolSigned = m.ProtocolSigned;
        editProtocolSignedAt = m.ProtocolSignedAt?.ToLocalTime();
        editDeputyChairProvided = m.DeputyChairProvided;
        editSecretaryProvided = m.SecretaryProvided;
        editSecretarySignsProtocols = m.SecretarySignsProtocols;
        editTemporaryChairProvided = m.TemporaryChairProvided;
        editBoardCompositionApproved = m.BoardCompositionApproved;
        editBoardApproved = m.BoardApproved;

        // Загружаем членов СД
        var members = await ctx.BoardMembers
            .Where(x => x.OsaMeetingId == meetingId)
            .OrderBy(x => x.FullName)
            .ToListAsync();
        var memberIds = members.Select(x => x.Id).ToList();
        var appointments = await ctx.BoardMemberAppointments
            .Where(x => memberIds.Contains(x.BoardMemberId) && x.Status.Code == "ACTIVE")
            .ToListAsync();

        boardMemberRows = members.Select(x => new BoardMemberRow
        {
            Name = x.FullName,
            MemberTypeId = x.BoardMemberTypeId,
            RoleId = appointments.FirstOrDefault(a => a.BoardMemberId == x.Id)?.RoleId,
            StartedAt = appointments.FirstOrDefault(a => a.BoardMemberId == x.Id)?.StartedAt.ToString("yyyy-MM-dd"),
            Account = x.Account,
            Email = x.Email,
            UserId = x.UserId
        }).ToList();

        // Восстанавливаем LdapLogin из Account, чтобы LDAP-дропдауны
        // показывали сохранённые значения при загрузке из БД
        foreach (var row in boardMemberRows)
        {
            if (!string.IsNullOrEmpty(row.Account))
                row.LdapLogin = row.Account;
        }

        // Загружаем или создаём запись Совета директоров
        var board = await ctx.BoardsOfDirectors.FirstOrDefaultAsync(x => x.OsaMeetingId == meetingId);
        if (board == null && editGosaYear.HasValue)
        {
            var draftStatusId = await ctx.BoardOfDirectorsStatuses
                .Where(s => s.Code == "DRAFT")
                .Select(s => s.Id)
                .FirstOrDefaultAsync();
            board = new SamorodinkaTech.Fiducia.Domain.Entities.BoardOfDirectors
            {
                Id = Guid.NewGuid(),
                OsaMeetingId = meetingId,
                GosaYear = editGosaYear.Value,
                StatusId = draftStatusId
            };
            ctx.BoardsOfDirectors.Add(board);
            await ctx.SaveChangesAsync();
        }
        editBoardOfDirectorsId = board?.Id;

        memberTypes = await ctx.BoardMemberTypes.OrderBy(x => x.Code).ToListAsync();
        boardRoles = await ctx.BoardRoles.OrderBy(x => x.SortOrder).ToListAsync();
        appointmentStatuses = await ctx.BoardMemberAppointmentStatuses.OrderBy(x => x.Code).ToListAsync();
        boardOfDirectorsStatuses = await ctx.BoardOfDirectorsStatuses.OrderBy(x => x.Code).ToListAsync();
        editTemporaryChairSelection = m.TemporaryChairSelection ?? "CHARTER_SENIOR";

        // Загружаем ОКОПФ первого ЮЛ для валидации
        var le = await ctx.LegalEntities.Include(x => x.Okopf).OrderBy(x => x.Name).FirstOrDefaultAsync();
        editLegalEntityId = le?.Id;
        editOkopfCode = le?.Okopf?.Code;
        editIsPao = le?.Okopf?.Code == "12247";
        editHasBoard = await ctx.LegalEntityBoardSettings.AnyAsync();
        editBoardMandatory = editIsPao
            || (editOkopfCode is "12267" or "12260" && (editShareholdersCount ?? 1) >= 50);
        if (editBoardMandatory)
            editBoardCompositionApproved = true;
        editBoardMinNumber = DeriveBoardMinimum(editOkopfCode, editShareholdersCount);

        // Умолчания: количество акционеров — из БД (legal_entities), участники СД — из последнего ОСА
        if (!editShareholdersCount.HasValue)
            editShareholdersCount = 1;

        if (!editBoardMemberNumber.HasValue)
        {
            var last = await ctx.OsaMeetings
                .Where(x => x.Id != meetingId && x.BoardMemberNumber != null)
                .OrderByDescending(x => x.CreatedAt)
                .Select(x => (int?)x.BoardMemberNumber)
                .FirstOrDefaultAsync();
            editBoardMemberNumber = last ?? editBoardMinNumber;
        }

        // Пересчитываем минимум с учётом уточнённого количества акционеров
        editBoardMinNumber = DeriveBoardMinimum(editOkopfCode, editShareholdersCount);

        saveError = null;
        saveSuccess = null;
        gosaError = null;

        await LoadMeetingFiles();
        await LoadFirstBoardTemplateSummary(ctx);
        StateHasChanged();
    }

