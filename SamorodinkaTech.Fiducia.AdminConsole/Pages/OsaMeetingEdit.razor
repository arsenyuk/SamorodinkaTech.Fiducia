    private async Task InstantiateFirstBoardTemplate(IApplicationDbContext ctx, Guid? legalEntityId)
    {
        if (!legalEntityId.HasValue)
        {
            Logger.LogWarning("Пропуск инстанцирования шаблона FIRST_BOARD: не задан LegalEntityId");
            return;
        }

        var template = await ctx.TplOrgIntents
            .Include(t => t.Stages)!.ThenInclude(s => s.Offers)!.ThenInclude(o => o.Tasks)
            .FirstOrDefaultAsync(t => t.Code == "FIRST_BOARD");
        if (template == null)
        {
            Logger.LogWarning("Пропуск инстанцирования: шаблон FIRST_BOARD не найден");
            return;
        }

        var intent = new OrgIntent
        {
            Id = Guid.NewGuid(),
            LegalEntityId = legalEntityId.Value,
            TemplateIntentId = template.Id,
            Name = template.Name,
            Description = template.Description,
            SortOrder = template.SortOrder,
            Status = "PLANNED"
        };
        ctx.OrgIntents.Add(intent);

        if (template.Stages != null)
        {
            foreach (var ts in template.Stages.OrderBy(s => s.SortOrder))
            {
                var stage = new OrgStage
                {
                    Id = Guid.NewGuid(),
                    IntentId = intent.Id,
                    TemplateStageId = ts.Id,
                    Name = ts.Name,
                    Description = ts.Description,
                    SortOrder = ts.SortOrder,
                    Status = "PLANNED"
                };
                ctx.OrgStages.Add(stage);

                if (ts.Offers != null)
                {
                    foreach (var to in ts.Offers.OrderBy(o => o.SortOrder))
                    {
                        var offer = new OrgOffer
                        {
                            Id = Guid.NewGuid(),
                            StageId = stage.Id,
                            TemplateOfferId = to.Id,
                            Name = to.Name,
                            Description = to.Description,
                            SortOrder = to.SortOrder,
                            Status = "PLANNED"
                        };
                        ctx.OrgOffers.Add(offer);

                        if (to.Tasks != null)
                        {
                            foreach (var tt in to.Tasks.OrderBy(t => t.SortOrder))
                            {
                                ctx.OrgTasks.Add(new OrgTask
                                {
                                    Id = Guid.NewGuid(),
                                    OfferId = offer.Id,
                                    TemplateTaskId = tt.Id,
                                    Name = tt.Name,
                                    Description = tt.Description,
                                    SortOrder = tt.SortOrder,
                                    Status = "PLANNED",
                                    AssignedRoleId = tt.AssignedRoleId
                                });
                            }
                        }
                    }
                }
            }
        }

        Logger.LogDebug("Шаблон FIRST_BOARD инстанцирован для LegalEntity {LegalEntityId}", legalEntityId);
    }

    private async Task LoadFirstBoardTemplateSummary(IApplicationDbContext ctx)
    {
        _firstBoardTemplateSummary = null;
        if (!editBoardCompositionApproved || !editHasBoard)
            return;

        var template = await ctx.TplOrgIntents
            .Include(t => t.Stages)!.ThenInclude(s => s.Offers)
            .FirstOrDefaultAsync(t => t.Code == "FIRST_BOARD");
        if (template == null)
        {
            _firstBoardTemplateSummary = "Шаблон «Первое заседание» не найден.";
            return;
        }

        var stageCount = template.Stages?.Count ?? 0;
        var offerCount = template.Stages?.Sum(s => s.Offers?.Count ?? 0) ?? 0;
        _firstBoardTemplateSummary = $"Шаблон «{template.Name}»: {stageCount} этап(а), {offerCount} задач(и) будут созданы для юридического лица.";

        // Сводка по активации/деактивации СД
        _boardActivationSummary = null;
        var boardDate = editGosaStart;
        var newBoardName = editGosaYear.HasValue ? $"Совет директоров {editGosaYear.Value}" : "новый состав";

        var prevBoard = await ctx.BoardsOfDirectors
            .Where(b => b.Status.Code == "ACTIVE")
            .OrderByDescending(b => b.StartedAt)
            .FirstOrDefaultAsync();
        if (prevBoard != null)
        {
            var prevName = prevBoard.GosaYear.HasValue ? $"Совет директоров {prevBoard.GosaYear.Value}" : "предыдущий состав";
            _boardActivationSummary = $"Состав «{prevName}» будет деактивирован (окончание полномочий: {boardDate.AddDays(-1):dd.MM.yyyy}). ";
        }
        _boardActivationSummary += $"«{newBoardName}» будет активирован (дата начала полномочий: {boardDate:dd.MM.yyyy}).";
    }

