    private async void OnBoardApprovedChanged()
    {
        if (editBoardApproved)
        {
            // СД утверждён → Состав СД утверждён автоматически
            if (!editBoardCompositionApproved)
            {
                editBoardCompositionApproved = true;
                OnBoardCompositionChanged();
            }
        }
        else
        {
            // Сняли «Совет директоров утверждён» → очищаем состав
