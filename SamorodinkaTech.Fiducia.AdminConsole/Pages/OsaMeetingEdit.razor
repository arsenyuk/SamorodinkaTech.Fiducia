                            </div>
                            <div class="col-md-4">
                                <strong>Состав утверждён:</strong> @(editBoardCompositionApproved ? "да" : "нет")
                                @if (editSecretaryProvided) { <span>| <strong>Секретарь:</strong> да</span> }
                                @if (editTemporaryChairProvided) { <span>| <strong>Вр. предс.:</strong> @TempChairLabel</span> }
                            </div>
                        </div>
                    </div>
                </div>
                @if (editBoardCompositionApproved && boardMemberRows.Any(r => r.RoleId != boardRoles.FirstOrDefault(x => x.Code == "SECRETARY")?.Id))
                {
                    var secRoleId = boardRoles.FirstOrDefault(x => x.Code == "SECRETARY")?.Id;
                    <div class="mt-2">
                        <strong>Состав СД:</strong>
                        @{
                            var typeParts = new List<string>();
                            if (editExecDirectors) typeParts.Add($"исполнительных: {editExecDirectorsCount ?? 0}");
                            if (editNonExecDirectors) typeParts.Add($"внешних: {editNonExecDirectorsCount ?? 0}");
                            if (editIndepDirectors) typeParts.Add($"независимых: {editIndepDirectorsCount ?? 0}");
                        }
                        @if (typeParts.Count > 0)
                        {
                            <span class="text-muted small"> (@string.Join(", ", typeParts))</span>
                        }
                        <table class="table table-sm table-borderless small mb-0 mt-1">
                            <thead>
                                <tr><th>ФИО</th><th>Роль</th><th>Тип участника</th></tr>
                            </thead>
                            <tbody>
                            @foreach (var row in boardMemberRows.Where(r => r.RoleId != secRoleId))
                            {
                                <tr>
                                    <td>@(string.IsNullOrWhiteSpace(row.Name) ? "—" : row.Name)</td>
                                    <td>@(boardRoles.FirstOrDefault(r => r.Id == row.RoleId)?.Name ?? "—")</td>
                                    <td>@(memberTypes.FirstOrDefault(t => t.Id == row.MemberTypeId)?.Name ?? "—")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                @if (meetingFiles.Any())
                {
                    <div class="mt-2">
                        <strong>Файлы (@meetingFiles.Count):</strong>
                        <table class="table table-sm table-borderless small mb-0 mt-1">
                            <thead>
                                <tr><th>Тип</th><th>Наименование</th><th>Имя файла</th><th>Размер</th></tr>
                            </thead>
                            <tbody>
                            @foreach (var mf in meetingFiles)
                            {
                                <tr>
                                    <td><span class="badge @FileTypeBadge(mf.FileType)">@FileTypeLabel(mf.FileType)</span></td>
                                    <td>@(mf.DisplayName ?? "—")</td>
                                    <td>@mf.FileName</td>
                                    <td>@FormatSize(mf.SizeBytes)</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                @if (!isFinalized && editBoardCompositionApproved && editHasBoard)
                {
                    @if (!string.IsNullOrEmpty(_boardActivationSummary))
                    {
                        <div class="alert alert-info py-2 mt-2">
                            🔄 <strong>Утверждение нового состава Совета директоров</strong>
                            <div class="small mt-1">@_boardActivationSummary</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_firstBoardTemplateSummary))
                    {
                        <div class="alert alert-success py-2 mt-2">
                            ✅ <strong>При финализации будет создан план задач «Первое заседание СД»</strong>
                            <div class="small mt-1">@_firstBoardTemplateSummary</div>
                        </div>
                    }
                }
                @if (isFinalized)
                {
                    <div class="alert alert-success py-2">
                        <div>✅ <strong>ОСА зафиксирована</strong></div>
                        <div class="small mt-1">Дата: @finalizedAt?.ToString("dd.MM.yyyy HH:mm") | Кем: Администратор</div>
                        @if (_firstBoardTemplateCreated)
                        {
                            <div class="small mt-1">📋 План задач «Первое заседание СД» создан.</div>
                        }
                    </div>
                }
            }

            @if (!string.IsNullOrEmpty(saveError))
            {
                <div class="alert alert-danger">❌ @saveError</div>
            }
            @if (!string.IsNullOrEmpty(saveSuccess))
            {
                <div class="alert alert-success">✅ @saveSuccess</div>
            }

            <div class="d-flex gap-2">
                @if (isFinalized)
                {
                    <button class="btn btn-outline-primary" @onclick="PrevStep" disabled="@(currentStep == 0)">← Назад</button>
                }
                else
                {
                    <button class="btn btn-outline-primary" @onclick="PrevStep" disabled="@(currentStep == 0)">← Назад</button>
                    @if (currentStep < wizardSteps.Length - 1)
                    {
                        <button class="btn btn-primary" @onclick="NextStep" disabled="@(!CanAdvance)">Далее →</button>
                    }
                    @if (currentStep == wizardSteps.Length - 1)
                    {
                        <button class="btn btn-success mx-auto" @onclick="Finalize">Завершить</button>
                    }
                    else
                    {
                        <button class="btn btn-success mx-auto" @onclick="QuickSaveAndNotify">Сохранить</button>
                    }
                    <button class="btn btn-danger" @onclick="Delete">Удалить</button>
                }
            </div>
        </div>
    </div>

@code {
    [Parameter] public Guid Id { get; set; }
    private List<OsaForm> osaForms = new();
    private List<OsaMeetingVm> osaMeetings = new();

    // Режим создания
    private bool showForm;
    private Guid selectedOsaFormId;
    private string? selectedFormCode;
    private DateOnly gosaStart;
    private DateOnly gosaEnd;
    private int? gosaYear;
    private bool createAbsenteeVoting;
    private DateTime createBallotDeadline = DateTime.UtcNow.AddDays(20);
    private DateTime? editBallotDeadline;
    private string createTitle = string.Empty;

    // Режим редактирования
    private Guid? editingMeetingId;
    private Guid editingFormId;
    private bool editIsGosa;
    private DateOnly editGosaStart;
    private DateOnly editGosaEnd;
    private string editTitle = string.Empty;
    private int? editGosaYear;
    private int? editShareholdersCount;
    private int? editBoardMemberNumber;
    private bool editExecDirectors;
    private int? editExecDirectorsCount;
    private bool editNonExecDirectors;
    private int? editNonExecDirectorsCount;
    private bool editIndepDirectors;
    private int? editIndepDirectorsCount;
    private int? editBoardMinNumber;
    private string? editOkopfCode;
    private bool editIsPao;
    private bool editHasBoard;
    private bool editShareholdersListReceived;
    private bool editAbsenteeVoting;
    private bool editBoardMandatory;
    private bool editBoardApproved;
    private bool editBoardCompositionApproved;
    private bool editOsaHeld;
    private bool editProtocolSigned;
    private DateTime? editProtocolSignedAt;
    private bool editDeputyChairProvided;
    private bool editSecretaryProvided = true;
    private bool editSecretarySignsProtocols;
    private bool editTemporaryChairProvided;
    private string? editTemporaryChairSelection = "CHARTER_SENIOR";
    private Guid? editBoardOfDirectorsId;
    private Guid? editLegalEntityId;
    private bool ldapEnabled;
    private IBoardMemberLdapService? ldapSvc;
    private List<BoardMemberCandidate> ldapCandidates = new();
    private Dictionary<string, Guid> ldapEmailToUserId = new(StringComparer.OrdinalIgnoreCase);
    private string? ldapDuplicateWarning;
    private List<BoardMemberRow> boardMemberRows = new();
    private bool _boardInitializing;
    private List<BoardMemberType> memberTypes = new();
    private List<BoardRole> boardRoles = new();
    private List<BoardMemberAppointmentStatus> appointmentStatuses = new();
    private List<BoardOfDirectorsStatus> boardOfDirectorsStatuses = new();
    private string? _firstBoardTemplateSummary;
    private bool _firstBoardTemplateCreated;
    private string? _boardActivationSummary;
    private bool isFinalized;
    private DateTime? finalizedAt;

    // Мастер
    private int currentStep;
    private static readonly string[] wizardSteps = { "Параметры", "Проведение", "Протокол", "Совет директоров", "Файлы", "Финализация" };

    private async Task GoToStep(int step)
    {
        Logger.LogDebug("GoToStep вызван: step={Step}, currentStep={Current}, isFinalized={Finalized}", step, currentStep, isFinalized);
        if (step == currentStep) return;

        if (!isFinalized)
        {
            // Вперёд: все промежуточные шаги должны пройти валидацию
            if (step > currentStep)
            {
                for (int i = currentStep; i < step; i++)
                {
                    if (!IsStepValid(i))
                    {
                        Logger.LogDebug("GoToStep заблокирован: шаг {Step} не прошёл валидацию", i);
                        return;
                    }
                }
            }

            saveError = null;
            saveSuccess = null;
            await QuickSave();
            if (!string.IsNullOrEmpty(saveError)) return;
        }

        currentStep = step;

        // При переходе на вкладку «Совет директоров»: подгружаем актуальный состав из БД
        if (step == 3 && editBoardCompositionApproved)
        {
            _boardInitializing = true;
            await LoadBoardMembersFromDb();
        }

        StateHasChanged();
        Logger.LogDebug("GoToStep переход выполнен: currentStep={Current}", currentStep);
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (_boardInitializing)
        {
            _boardInitializing = false;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    /// <summary>Валидность контента шага (пройдена ли валидация для перехода дальше).</summary>
    private bool IsStepValid(int step) => step switch
    {
        0 => true,
        1 => !editHasBoard || (editShareholdersListReceived && editShareholdersCount.HasValue),
        2 => IsProtocolStepValid(),
        3 => editBoardCompositionApproved
            ? AreBoardMemberFieldsValid() && ldapDuplicateWarning == null
            : !editHasBoard,
        4 => !editIsGosa || !editHasBoard || meetingFiles.Any(),
        _ => true
    };

    /// <summary>
    /// Клиентская валидация шага «Протокол»: зеркалит все проверки даты из SaveEdit.
    /// </summary>
    private bool IsProtocolStepValid()
    {
        if (!editProtocolSigned || !editProtocolSignedAt.HasValue)
            return false;

        if (editProtocolSignedAt > DateTime.Now)
            return false;

        var referenceDate = editAbsenteeVoting && editBallotDeadline.HasValue
            ? editBallotDeadline.Value
            : (editIsGosa ? editGosaEnd.ToDateTime(TimeOnly.MinValue) : DateTime.MinValue);

        if (referenceDate == DateTime.MinValue)
            return true;

        var signedAt = (DateTime)editProtocolSignedAt;
        var deadline = referenceDate.AddDays(3);
        return signedAt >= referenceDate && signedAt <= deadline;
    }

    /// <summary>Возвращает текст ошибки валидации протокола для показа на вкладке.</summary>
    private string? GetProtocolValidationError()
    {
        if (!editProtocolSigned)
            return "Протокол не подписан";
        if (!editProtocolSignedAt.HasValue)
            return "Не указана дата подписания протокола";
        if (editProtocolSignedAt > DateTime.Now)
            return "Дата подписания протокола не может быть в будущем";

        var referenceDate = editAbsenteeVoting && editBallotDeadline.HasValue
            ? editBallotDeadline.Value
            : (editIsGosa ? editGosaEnd.ToDateTime(TimeOnly.MinValue) : DateTime.MinValue);

        if (referenceDate != DateTime.MinValue)
        {
            var signedAt = (DateTime)editProtocolSignedAt;
            if (signedAt < referenceDate)
                return $"Дата подписания не может быть раньше {referenceDate:dd.MM.yyyy} (даты завершения ОСА)";
            var deadline = referenceDate.AddDays(3);
            if (signedAt > deadline)
                return $"Дата подписания не может быть позднее {deadline:dd.MM.yyyy} (3 дня после завершения ОСА)";
        }

        return null;
    }

    /// <summary>Клиентская валидация: количество членов СД совпадает с заявленным, все поля роли «Член СД» заполнены.</summary>
    private bool AreBoardMemberFieldsValid()
    {
        if (!editHasBoard && !editBoardCompositionApproved) return true;

        // Количество строк (без секретаря и временного председательствующего) должно совпадать с заявленным и быть не меньше минимума
        var secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
        var nonSecretaryCount = boardMemberRows.Count(r => r.RoleId != secRoleId && r.RoleId != tempChairRoleId);
        if (editBoardMemberNumber.HasValue && nonSecretaryCount != editBoardMemberNumber.Value)
            return false;
        if (editBoardMinNumber.HasValue && nonSecretaryCount < editBoardMinNumber.Value)
            return false;

        // Все строки (кроме секретаря и временного председательствующего) должны быть заполнены
        var memberRows = boardMemberRows
            .Where(r => r.RoleId != secRoleId && r.RoleId != tempChairRoleId)
            .ToList();
        // Когда типы директоров не настроены — MemberTypeId не обязателен
        var typesConfigured = (editExecDirectors && editExecDirectorsCount > 0)
            || (editNonExecDirectors && editNonExecDirectorsCount > 0)
            || (editIndepDirectors && editIndepDirectorsCount > 0);
        if (memberRows.Any(r =>
            string.IsNullOrWhiteSpace(r.Name)
            || (typesConfigured && !r.MemberTypeId.HasValue)))
            return false;

        // Дублирование ФИО среди членов СД недопустимо
        var dupCount = memberRows
            .Where(r => !string.IsNullOrWhiteSpace(r.Name))
            .GroupBy(r => r.Name.Trim())
            .Count(g => g.Count() > 1);
        if (dupCount > 0)
            return false;

        // Секретарь обязан иметь STAFF, остальные — не могут
        if (secRoleId.HasValue && staffMemberTypeId.HasValue)
        {
            foreach (var row in boardMemberRows)
            {
                var isSec = row.RoleId == secRoleId;
                var isStaff = row.MemberTypeId == staffMemberTypeId;
                if ((isSec && !isStaff) || (!isSec && isStaff))
                    return false;
            }
        }

        // Временный председательствующий — не больше одного
        var tcRoleId = tempChairRoleId;
        if (tcRoleId.HasValue && boardMemberRows.Count(r => r.RoleId == tcRoleId) > 1)
            return false;

        // Временный председательствующий должен быть заполнен (ФИО, тип участника)
        if (tcRoleId.HasValue && editTemporaryChairProvided && editTemporaryChairSelection == "GMS_DECISION")
        {
            var tcRow = boardMemberRows.FirstOrDefault(r => r.RoleId == tcRoleId.Value);
            if (tcRow == null
                || string.IsNullOrWhiteSpace(tcRow.Name)
                || !tcRow.MemberTypeId.HasValue)
                return false;
        }

        return true;
    }

    private string GetBoardValidationFailReason()
    {
        if (!editHasBoard && !editBoardCompositionApproved) return "no-board";
        var secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
        var nonSecretaryCount = boardMemberRows.Count(r => r.RoleId != secRoleId && r.RoleId != tempChairRoleId);
        if (editBoardMemberNumber.HasValue && nonSecretaryCount != editBoardMemberNumber.Value)
            return $"count-mismatch:{nonSecretaryCount}!={editBoardMemberNumber}";
        if (editBoardMinNumber.HasValue && nonSecretaryCount < editBoardMinNumber.Value)
            return $"below-min:{nonSecretaryCount}<{editBoardMinNumber}";
        var memberRows = boardMemberRows.Where(r => r.RoleId != secRoleId && r.RoleId != tempChairRoleId).ToList();
        foreach (var r in memberRows)
        {
            if (string.IsNullOrWhiteSpace(r.Name)) return "empty-name";
        }
        var typesConfigured = (editExecDirectors && editExecDirectorsCount > 0)
            || (editNonExecDirectors && editNonExecDirectorsCount > 0)
            || (editIndepDirectors && editIndepDirectorsCount > 0);
        if (typesConfigured && memberRows.Any(r => !r.MemberTypeId.HasValue)) return "null-type";
        var dupCount = memberRows.Where(r => !string.IsNullOrWhiteSpace(r.Name))
            .GroupBy(r => r.Name.Trim()).Count(g => g.Count() > 1);
        if (dupCount > 0) return "duplicate";
        if (secRoleId.HasValue && staffMemberTypeId.HasValue)
        {
            foreach (var row in boardMemberRows)
            {
                var isSec = row.RoleId == secRoleId;
                var isStaff = row.MemberTypeId == staffMemberTypeId;
                if (isSec && !isStaff) return "sec-not-staff";
                if (!isSec && isStaff) return "non-sec-is-staff";
            }
        }
        var tcRoleId = tempChairRoleId;
        if (tcRoleId.HasValue && boardMemberRows.Count(r => r.RoleId == tcRoleId) > 1)
            return "multi-tempchair";
        if (tcRoleId.HasValue && editTemporaryChairProvided && editTemporaryChairSelection == "GMS_DECISION")
        {
            var tcRow = boardMemberRows.FirstOrDefault(r => r.RoleId == tcRoleId.Value);
            if (tcRow == null) return "tempchair-missing";
            if (string.IsNullOrWhiteSpace(tcRow.Name)) return "tempchair-empty-name";
            if (!tcRow.MemberTypeId.HasValue) return "tempchair-null-type";
        }
        return "OK";
    }

    private bool CanAdvance => IsStepValid(currentStep);

    /// <summary>Возвращает true, если поля членов СД не заполнены (для показа предупреждения).</summary>
    private bool AreBoardFieldsIncomplete()
    {
        if (!editBoardCompositionApproved) return false;
        // Поля проверяются, даже если editHasBoard == false (обязательный СД для ПАО)

        var secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
        var memberRows = boardMemberRows
            .Where(r => r.RoleId != secRoleId && r.RoleId != tempChairRoleId)
            .ToList();

        return memberRows.Any(r =>
            string.IsNullOrWhiteSpace(r.Name)
            || !r.MemberTypeId.HasValue);
    }

    private async Task NextStep()
    {
        if (currentStep >= wizardSteps.Length - 1) return;
        if (!isFinalized)
        {
            saveError = null;
            saveSuccess = null;
            await QuickSave();
            if (!string.IsNullOrEmpty(saveError)) return;
        }
        currentStep++;
        if (currentStep == 3 && editBoardCompositionApproved)
            await LoadBoardMembersFromDb();
    }

    private async Task PrevStep()
    {
        if (currentStep <= 0) return;
        if (!isFinalized)
        {
            saveError = null;
            saveSuccess = null;
            await QuickSave();
            if (!string.IsNullOrEmpty(saveError)) return;
        }
        currentStep--;
        if (currentStep == 3 && editBoardCompositionApproved)
            await LoadBoardMembersFromDb();
    }

    private async Task Finalize()
    {
        if (!editingMeetingId.HasValue || isFinalized) return;
        try
        {
            // Полная серверная валидация перед финализацией
            await SaveEdit();
            if (!string.IsNullOrEmpty(saveError)) return;

            await using var ctx = await DbFactory.CreateDbContextAsync();
            var m = await ctx.OsaMeetings.FirstOrDefaultAsync(x => x.Id == editingMeetingId.Value);
            if (m is null) return;
            m.Status = "APPROVED";
            m.FinalizedAt = DateTime.UtcNow;

            // Если в рамках данного ОСА утверждён новый состав СД — активируем его
            // и деактивируем предыдущий
            if (editBoardCompositionApproved && editHasBoard && editBoardOfDirectorsId.HasValue)
            {
                var boardDate = m.GosaWindowStart.HasValue
                    ? m.GosaWindowStart.Value
                    : DateOnly.FromDateTime(DateTime.UtcNow);

                var inactiveStatusId = await ctx.BoardOfDirectorsStatuses
                    .Where(s => s.Code == "INACTIVE")
                    .Select(s => s.Id)
                    .FirstOrDefaultAsync();
                var activeStatusId = await ctx.BoardOfDirectorsStatuses
                    .Where(s => s.Code == "ACTIVE")
                    .Select(s => s.Id)
                    .FirstOrDefaultAsync();

                // Деактивируем предыдущий действующий СД (не связанный с текущим ОСА)
                var prevBoard = await ctx.BoardsOfDirectors
                    .Where(b => b.OsaMeetingId != editingMeetingId.Value
                             && b.Status.Code == "ACTIVE")
                    .OrderByDescending(b => b.StartedAt)
                    .FirstOrDefaultAsync();
                if (prevBoard != null)
                {
                    prevBoard.EndedAt = boardDate.AddDays(-1);
                    prevBoard.StatusId = inactiveStatusId;
                }

                // Активируем СД текущего ОСА
                var currentBoard = await ctx.BoardsOfDirectors
                    .FirstOrDefaultAsync(b => b.Id == editBoardOfDirectorsId.Value);
                if (currentBoard != null)
                {
                    currentBoard.StartedAt = boardDate;
                    currentBoard.StatusId = activeStatusId;

                    // Переводим назначения членов СД из DRAFT в ACTIVE
                    var appointmentDraftId = await ctx.BoardMemberAppointmentStatuses
                        .Where(s => s.Code == "DRAFT")
                        .Select(s => s.Id)
                        .FirstOrDefaultAsync();
                    var appointmentActiveId = await ctx.BoardMemberAppointmentStatuses
                        .Where(s => s.Code == "ACTIVE")
                        .Select(s => s.Id)
                        .FirstOrDefaultAsync();
                    if (appointmentDraftId != Guid.Empty && appointmentActiveId != Guid.Empty)
                    {
                        var appointmentIds = await ctx.BoardMembers
                            .Where(bm => bm.BoardOfDirectorsId == currentBoard.Id)
                            .SelectMany(bm => ctx.BoardMemberAppointments
                                .Where(a => a.BoardMemberId == bm.Id && a.StatusId == appointmentDraftId))
                            .ToListAsync();
                        foreach (var app in appointmentIds)
                            app.StatusId = appointmentActiveId;
                    }
                }

                // Запускаем создание задач по шаблону «Первое заседание»
                await InstantiateFirstBoardTemplate(ctx, editLegalEntityId);
                _firstBoardTemplateCreated = true;
            }

            // TODO: получить ID текущего пользователя
            await ctx.SaveChangesAsync();
            isFinalized = true;
            finalizedAt = m.FinalizedAt.Value.ToLocalTime();
        }
        catch (Exception ex)
        {
            saveError = ExceptionFlattener.Unwrap(ex);
        }
    }

    private async Task QuickSave()
    {
        if (!editingMeetingId.HasValue) return;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var m = await ctx.OsaMeetings.FirstOrDefaultAsync(x => x.Id == editingMeetingId.Value);
            if (m is null) return;

            if (editIsGosa) { m.GosaWindowStart = editGosaStart; m.GosaWindowEnd = editGosaEnd; m.GosaYear = editGosaYear; }
            m.Title = editIsGosa ? BuildGosaTitle(editGosaStart) : (string.IsNullOrWhiteSpace(editTitle) ? null : editTitle.Trim());
            m.AbsenteeVoting = editAbsenteeVoting;
            m.BallotDeadline = editAbsenteeVoting && editBallotDeadline.HasValue ? ((DateTime)editBallotDeadline).ToUniversalTime() : null;
            m.ShareholdersListReceived = editShareholdersListReceived;
            m.ShareholdersCount = editHasBoard ? editShareholdersCount : null;
            m.BoardMemberNumber = editHasBoard ? editBoardMemberNumber : null;
            m.ExecutiveDirectorsParticipate = editExecDirectors;
            m.ExecutiveDirectorsCount = editExecDirectors ? editExecDirectorsCount : null;
            m.NonExecutiveDirectorsParticipate = editNonExecDirectors;
            m.NonExecutiveDirectorsCount = editNonExecDirectors ? editNonExecDirectorsCount : null;
            m.IndependentDirectorsParticipate = editIndepDirectors;
            m.IndependentDirectorsCount = editIndepDirectors ? editIndepDirectorsCount : null;
            m.OsaHeld = editOsaHeld;
            m.ProtocolSigned = editProtocolSigned && editOsaHeld;
            m.ProtocolSignedAt = editProtocolSigned && editProtocolSignedAt.HasValue ? ((DateTime)editProtocolSignedAt).ToUniversalTime() : null;
            m.DeputyChairProvided = editDeputyChairProvided;
            m.SecretaryProvided = editSecretaryProvided;
            m.SecretarySignsProtocols = editSecretaryProvided && editSecretarySignsProtocols;
            m.TemporaryChairProvided = editTemporaryChairProvided;
            m.TemporaryChairSelection = editTemporaryChairProvided ? editTemporaryChairSelection : null;
            m.BoardCompositionApproved = editBoardCompositionApproved;
            m.BoardMandatory = editBoardMandatory;
            m.BoardApproved = editBoardApproved;

            // Привязываем строки без UserId к справочнику пользователей (LDAP)
            await EnsureUserIds(ctx, validateExisting: true);

            // Создаём/обновляем запись Совета директоров
            var board = await ctx.BoardsOfDirectors.FirstOrDefaultAsync(x => x.OsaMeetingId == editingMeetingId.Value);
            if (board == null)
            {
                var draftStatusId = boardOfDirectorsStatuses.FirstOrDefault(s => s.Code == "DRAFT")?.Id ?? Guid.Empty;
                board = new SamorodinkaTech.Fiducia.Domain.Entities.BoardOfDirectors
                {
                    Id = Guid.NewGuid(),
                    OsaMeetingId = editingMeetingId.Value,
                    GosaYear = editGosaYear,
                    StatusId = draftStatusId
                };
                ctx.BoardsOfDirectors.Add(board);
            }
            else
            {
                board.GosaYear = editGosaYear;
            }
            editBoardOfDirectorsId = board.Id;

            // Сохраняем состав СД, если утверждён
            if (editBoardCompositionApproved && editHasBoard)
            {
                var oldMembers = await ctx.BoardMembers.Where(x => x.OsaMeetingId == editingMeetingId.Value).ToListAsync();
                var oldMemberIds = oldMembers.Select(x => x.Id).ToList();
                var oldAppointments = await ctx.BoardMemberAppointments.Where(x => oldMemberIds.Contains(x.BoardMemberId)).ToListAsync();
                ctx.BoardMemberAppointments.RemoveRange(oldAppointments);
                ctx.BoardMembers.RemoveRange(oldMembers);
                var _secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
                var _tcRoleId = boardRoles.FirstOrDefault(r => r.Code == "TEMP_CHAIR")?.Id;
                foreach (var row in boardMemberRows.Where(x => !string.IsNullOrWhiteSpace(x.Name) || x.RoleId == _secRoleId || x.RoleId == _tcRoleId))
                {
                    var member = new BoardMember
                    {
                        Id = Guid.NewGuid(),
                        OsaMeetingId = editingMeetingId.Value,
                        BoardOfDirectorsId = editBoardOfDirectorsId,
                        FullName = row.Name.Trim(),
                        BoardMemberTypeId = row.MemberTypeId,
                        Account = string.IsNullOrWhiteSpace(row.Account) ? null : row.Account.Trim(),
                        Email = string.IsNullOrWhiteSpace(row.Email) ? null : row.Email.Trim(),
                        UserId = row.UserId
                    };
                    ctx.BoardMembers.Add(member);
                    if (row.RoleId.HasValue && row.StartedAt is not null && DateOnly.TryParse(row.StartedAt, out var startedAt))
                    {
                        ctx.BoardMemberAppointments.Add(new BoardMemberAppointment
                        {
                            Id = Guid.NewGuid(),
                            BoardMemberId = member.Id,
                            RoleId = row.RoleId.Value,
                            RoleCode = boardRoles.FirstOrDefault(r => r.Id == row.RoleId.Value)?.Code ?? "",
                            StartedAt = startedAt,
                            StatusId = appointmentStatuses.FirstOrDefault(s => s.Code == "DRAFT")?.Id ?? Guid.Empty
                        });
                    }
                }
            }
            else if (editHasBoard && editingMeetingId.HasValue)
            {
                // Состав не утверждён — удаляем всё с сервера
                var oldMembers = await ctx.BoardMembers.Where(x => x.OsaMeetingId == editingMeetingId.Value).ToListAsync();
                var oldMemberIds = oldMembers.Select(x => x.Id).ToList();
                var oldAppointments = await ctx.BoardMemberAppointments.Where(x => oldMemberIds.Contains(x.BoardMemberId)).ToListAsync();
                ctx.BoardMemberAppointments.RemoveRange(oldAppointments);
                ctx.BoardMembers.RemoveRange(oldMembers);
            }

            await ctx.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "QuickSave: ошибка сохранения ОСА {OsaMeetingId}", editingMeetingId);
            saveError = $"Ошибка сохранения: {ExceptionFlattener.Unwrap(ex)}";
        }
    }

