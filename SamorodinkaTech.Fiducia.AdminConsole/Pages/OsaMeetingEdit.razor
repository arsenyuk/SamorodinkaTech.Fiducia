    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await LoadData();
        await OpenEdit(Id);

        ldapEnabled = Config.GetValue<bool>("Ldap:Enabled");
        if (ldapEnabled)
        {
            try
            {
                ldapSvc = ServiceProvider.GetRequiredService<IBoardMemberLdapService>();
                ldapCandidates = (await ldapSvc.GetCandidatesAsync()).ToList();

                // Строим маппинг email → UserId для привязки кандидатов к справочнику пользователей
                await using var ctx = await DbFactory.CreateDbContextAsync();
                var candidateEmails = ldapCandidates
                    .Where(c => !string.IsNullOrEmpty(c.Email))
                    .Select(c => c.Email!)
                    .ToList();
                var users = await ctx.Users
                    .Where(u => candidateEmails.Contains(u.Email))
                    .Select(u => new { u.Id, u.Email })
                    .ToListAsync();
                ldapEmailToUserId = users.ToDictionary(u => u.Email, u => u.Id, StringComparer.OrdinalIgnoreCase);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Не удалось загрузить кандидатов из LDAP");
                ldapCandidates = new();
            }
        }
    }

