                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-muted small mb-2">Файлы не прикреплены.</div>
                }
                <div class="d-flex gap-2 align-items-end">
                    <div>
                        <label class="form-label small">Тип файла</label>
                        <select class="form-select form-select-sm" @bind="newFileType" disabled="@isFinalized">
                            <option value="CHARTER">Устав</option>
                            <option value="PROTOCOL">Протокол</option>
                            <option value="REGULATION">Положение</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label small">Наименование</label>
                        <input class="form-control form-control-sm" @bind="newFileDisplayName" placeholder="Название документа" disabled="@isFinalized" />
                    </div>
                    <div>
                        <label class="form-label small">Файл</label>
                        <InputFile class="form-control form-control-sm" OnChange="OnFileSelected" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" disabled="@isFinalized" />
                    </div>
                </div>
                @if (uploadProgress > 0 && uploadProgress < 100)
                {
                    <div class="progress flex-grow-1 mt-1" style="max-width:200px">
                        <div class="progress-bar" style="width:@uploadProgress%">@uploadProgress%</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(fileError))
                {
                    <span class="text-danger small">@fileError</span>
                }
            </fieldset>
            }

            @if (currentStep == 5)
            {
                <div class="alert alert-info mb-3">
                    ℹ️ <strong>Финализация ОСА.</strong> После нажатия «Завершить» редактирование будет заблокировано.
                    Действия сотрудника основаны на юридически значимых документах (ЮЗД), переданных для ввода информации.
                </div>
                <div class="card bg-light mb-3">
                    <div class="card-body py-2">
