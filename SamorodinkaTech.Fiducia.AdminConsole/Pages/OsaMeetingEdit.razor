    private async Task LoadBoardMembersFromDb()
    {
        if (!editingMeetingId.HasValue) return;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var members = await ctx.BoardMembers
                .Where(x => x.OsaMeetingId == editingMeetingId.Value)
                .OrderBy(x => x.FullName)
                .ToListAsync();
            var memberIds = members.Select(x => x.Id).ToList();
            var appointments = await ctx.BoardMemberAppointments
                .Where(x => memberIds.Contains(x.BoardMemberId) && x.Status.Code == "ACTIVE")
                .ToListAsync();

            boardMemberRows = members.Select(x => new BoardMemberRow
            {
                Name = x.FullName,
                MemberTypeId = x.BoardMemberTypeId,
                RoleId = appointments.FirstOrDefault(a => a.BoardMemberId == x.Id)?.RoleId,
                StartedAt = appointments.FirstOrDefault(a => a.BoardMemberId == x.Id)?.StartedAt.ToString("yyyy-MM-dd"),
                Account = x.Account,
                Email = x.Email,
                UserId = x.UserId
            }).ToList();

            // Восстанавливаем LdapLogin из Account, чтобы LDAP-дропдауны
            // показывали сохранённые значения при загрузке из БД
            foreach (var row in boardMemberRows)
            {
                if (!string.IsNullOrEmpty(row.Account))
                    row.LdapLogin = row.Account;
            }

            // Удаляем пустые строки (не секретарь, не temp chair), оставшиеся от каскада @bind:after
            var secForCleanup = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
            if (editBoardMemberNumber.HasValue)
            {
                var filledCount = boardMemberRows
                    .Count(r => r.RoleId != secForCleanup && r.RoleId != tempChairRoleId && !string.IsNullOrWhiteSpace(r.Name));
                if (filledCount >= editBoardMemberNumber.Value)
                {
                    boardMemberRows.RemoveAll(r =>
                        r.RoleId != secForCleanup && r.RoleId != tempChairRoleId && string.IsNullOrWhiteSpace(r.Name));
                }
            }

            var wasInit = _boardInitializing;
            _boardInitializing = false; // При загрузке из БД методы работают без ограничений
            EnsureBoardMemberCount();
            ApplyTempChairRole();
            UpdateGosaCountFromTypes();
            _boardInitializing = wasInit; // Восстанавливаем для защиты от @bind:after каскада
            UpdateGosaCountFromTypes();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Не удалось загрузить состав СД для ОСА {OsaMeetingId}", editingMeetingId);
            saveError = $"Ошибка загрузки состава СД: {ExceptionFlattener.Unwrap(ex)}";
        }
    }

    /// <summary>Подгоняет количество строк (без секретаря и временного председательствующего) под editBoardMemberNumber.</summary>
    private void EnsureBoardMemberCount()
    {
        if (_boardInitializing) return;
        if (!editBoardCompositionApproved || !editHasBoard || !editBoardMemberNumber.HasValue)
            return;

        var secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
        var tcRoleId = tempChairRoleId;
        var nonSecretary = boardMemberRows
            .Where(r => r.RoleId != secRoleId && r.RoleId != tcRoleId)
            .ToList();
        var target = editBoardMemberNumber.Value;

        // Добавляем строки, если не хватает
        while (nonSecretary.Count < target)
        {
            var row = new BoardMemberRow
            {
                Name = "",
                RoleId = memberRoleId,
                StartedAt = DateTime.Today.ToString("yyyy-MM-dd")
            };
            // Вставляем перед секретарём, если он есть
            var secIndex = boardMemberRows.FindIndex(r => r.RoleId == secRoleId);
            if (secIndex >= 0)
                boardMemberRows.Insert(secIndex, row);
            else
                boardMemberRows.Add(row);
            nonSecretary.Add(row);
        }
        // Убираем лишние
        while (nonSecretary.Count > target)
        {
            var last = nonSecretary[^1];
            boardMemberRows.Remove(last);
            nonSecretary.RemoveAt(nonSecretary.Count - 1);
        }

        // Секретарь: добавляем, если предусмотрен и отсутствует
        if (editSecretaryProvided && secRoleId.HasValue && !boardMemberRows.Any(r => r.RoleId == secRoleId))
        {
            boardMemberRows.Add(new BoardMemberRow
            {
                Name = "",
                RoleId = secRoleId.Value,
                MemberTypeId = staffMemberTypeId,
                StartedAt = DateTime.Today.ToString("yyyy-MM-dd")
            });
        }
    }

    /// <summary>Вычисляет editBoardMemberNumber из суммы типов директоров.</summary>
    private void ComputeBoardMemberNumber()
    {
        if (_boardInitializing) return;
        var total = (editExecDirectors ? (editExecDirectorsCount ?? 0) : 0)
                  + (editNonExecDirectors ? (editNonExecDirectorsCount ?? 0) : 0)
                  + (editIndepDirectors ? (editIndepDirectorsCount ?? 0) : 0);
        editBoardMemberNumber = total > 0 ? total : 0;
    }

    /// <summary>Проставляет MemberTypeId в строках состава СД.</summary>
    private void UpdateGosaCountFromTypes()
    {
        if (_boardInitializing) return;
        // Проставляем MemberTypeId в существующих строках (без изменения количества)
        if (!editBoardCompositionApproved || boardMemberRows.Count == 0) return;

        var secRoleId = boardRoles.FirstOrDefault(r => r.Code == "SECRETARY")?.Id;
        int execCount = editExecDirectors ? (editExecDirectorsCount ?? 0) : 0;
        int nonExecCount = editNonExecDirectors ? (editNonExecDirectorsCount ?? 0) : 0;
        int indepCount = editIndepDirectors ? (editIndepDirectorsCount ?? 0) : 0;

        var rows = boardMemberRows.Where(r => r.RoleId != secRoleId && r.RoleId != tempChairRoleId).ToList();

        // Если счётчики типов не заданы — не трогаем существующие MemberTypeId (загруженные из БД)
        if (execCount == 0 && nonExecCount == 0 && indepCount == 0) return;

        // Снимаем все типы, затем распределяем заново: EXECUTIVE → NON_EXEC → INDEP
        foreach (var row in rows)
            row.MemberTypeId = null;

        int idx = 0;

        for (int i = 0; i < execCount && idx < rows.Count; i++, idx++)
            rows[idx].MemberTypeId = execMemberTypeId;
        for (int i = 0; i < nonExecCount && idx < rows.Count; i++, idx++)
            rows[idx].MemberTypeId = nonExecMemberTypeId;
        for (int i = 0; i < indepCount && idx < rows.Count; i++, idx++)
            rows[idx].MemberTypeId = indepMemberTypeId;

        StateHasChanged();
    }

    private void OnTempChairChanged()
    {
        if (!editTemporaryChairProvided)
            editTemporaryChairSelection = "CHARTER_SENIOR";
        ApplyTempChairRole();
    }

    private void HandleTempChairSelection(ChangeEventArgs e)
    {
        editTemporaryChairSelection = e.Value?.ToString() ?? "CHARTER_SENIOR";
        ApplyTempChairRole();
    }

    private void ApplyTempChairRole()
    {
        var tcRoleId = tempChairRoleId;
        if (!tcRoleId.HasValue) return;

        var shouldApply = editTemporaryChairProvided
            && editTemporaryChairSelection == "GMS_DECISION";

        var tempRow = boardMemberRows.FirstOrDefault(r => r.RoleId == tcRoleId);

        if (shouldApply && tempRow == null)
        {
            boardMemberRows.Insert(0, new BoardMemberRow
            {
                Name = "",
                RoleId = tcRoleId.Value,
                StartedAt = DateTime.Today.ToString("yyyy-MM-dd")
            });
        }
        else if (!shouldApply && tempRow != null)
        {
            boardMemberRows.Remove(tempRow);
        }

        StateHasChanged();
    }

