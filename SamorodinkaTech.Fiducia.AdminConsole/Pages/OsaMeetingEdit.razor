    private void OnLdapCandidateSelected(BoardMemberRow row, ChangeEventArgs e)
    {
        var login = e.Value?.ToString();
        row.LdapLogin = login;

        if (string.IsNullOrEmpty(login))
        {
            row.Name = string.Empty;
            row.Account = null;
            row.Email = null;
            row.UserId = null;
            StateHasChanged();
            return;
        }

        var candidate = ldapCandidates.FirstOrDefault(c => c.Login == login);
        if (candidate != null)
        {
            row.Name = candidate.FullName;
            row.Account = candidate.Login;
            row.Email = candidate.Email ?? string.Empty;

            // Привязка к справочнику пользователей по email
            if (!string.IsNullOrEmpty(candidate.Email) && ldapEmailToUserId.TryGetValue(candidate.Email, out var userId))
                row.UserId = userId;
            else
                row.UserId = null;
        }

        // Проверка дубликатов
        var dupLogins = boardMemberRows
            .GroupBy(r => r.LdapLogin)
            .Where(g => !string.IsNullOrEmpty(g.Key) && g.Count() > 1)
            .Select(g => g.First().Name)
            .ToList();
        ldapDuplicateWarning = dupLogins.Count > 0
            ? $"Сотрудник{(dupLogins.Count > 1 ? "и" : "")} «{string.Join("», «", dupLogins)}» уже добавлен{(dupLogins.Count > 1 ? "ы" : "")} в состав. Дублирование учётных записей недопустимо."
            : null;

        StateHasChanged();
    }

