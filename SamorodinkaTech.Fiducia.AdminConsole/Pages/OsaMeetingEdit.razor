    private void OnOsaTypeChanged(ChangeEventArgs e)
    {
        var idStr = e.Value?.ToString();
        if (Guid.TryParse(idStr, out var id))
        {
            var form = osaForms.FirstOrDefault(f => f.Id == id);
            selectedFormCode = form?.Code;
            selectedOsaFormId = id;
            if (selectedFormCode == "GOSA")
            {
                if (gosaStart.Year <= 1)
                    gosaStart = new DateOnly(DateTime.UtcNow.Year, 3, 1);
                gosaYear = gosaStart.Year;
                createTitle = BuildGosaTitle(gosaStart);
            }
        }
        else
        {
            selectedFormCode = null;
            selectedOsaFormId = Guid.Empty;
            createTitle = string.Empty;
        }
        StateHasChanged();
    }

    private async Task Save()
    {
        saveError = null;
        saveSuccess = null;
        gosaError = null;

        var form = osaForms.FirstOrDefault(f => f.Id == selectedOsaFormId);
        if (form is null)
        {
            saveError = "Выберите тип ОСА";
            return;
        }

        Logger.LogDebug("Серверная валидация ОСА тип {OsaFormCode}", form.Code);

        if (form.Code == "GOSA")
        {
            var (defStart, defEnd) = GosaSvc.GetDefaultWindow();
            if (gosaStart < defStart || gosaEnd > defEnd)
            {
                gosaError = $"Даты должны быть в пределах {defStart:dd.MM}–{defEnd:dd.MM}";
                Logger.LogWarning("Валидация не пройдена для ОСА тип {OsaFormCode}: {Errors}", form.Code, gosaError);
                return;
            }
            if (gosaEnd < gosaStart)
            {
                gosaError = "Завершение ОСА не может быть раньше начала ОСА";
                Logger.LogWarning("Валидация не пройдена для ОСА тип {OsaFormCode}: {Errors}", form.Code, gosaError);
                return;
            }
        }

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();

            // Проверка: не более 1 ГОСА в году
            if (form.Code == "GOSA" && gosaYear.HasValue)
            {
                var existing = await ctx.OsaMeetings
                    .AnyAsync(m => m.GosaYear == gosaYear.Value);
                if (existing)
                {
                    gosaError = $"ГОСА за {gosaYear.Value} год уже существует. Нельзя создать более одного ГОСА в году.";
                    Logger.LogWarning("Валидация не пройдена для ОСА тип {OsaFormCode}: {Errors}", form.Code, gosaError);
                    return;
                }
            }

            var meeting = new OsaMeeting
            {
                Id = Guid.NewGuid(),
                OsaFormId = form.Id,
                GosaWindowStart = form.Code == "GOSA" ? gosaStart : null,
                GosaWindowEnd = form.Code == "GOSA" ? gosaEnd : null,
                GosaYear = form.Code == "GOSA" ? gosaYear : null,
                AbsenteeVoting = form.Code == "VOSA" && createAbsenteeVoting,
                BallotDeadline = form.Code == "VOSA" && createAbsenteeVoting
                    ? createBallotDeadline.ToUniversalTime() : null,
                Title = form.Code == "GOSA" ? BuildGosaTitle(gosaStart) : (string.IsNullOrWhiteSpace(createTitle) ? null : createTitle.Trim())
            };
            ctx.OsaMeetings.Add(meeting);
            await ctx.SaveChangesAsync();

            saveSuccess = "Запись ОСА добавлена.";
            showForm = false;
            await LoadData();

            // Переход на редактирование
            await OpenEdit(meeting.Id);
        }
        catch (Exception ex)
        {
            saveError = ExceptionFlattener.Unwrap(ex);
        }
    }

