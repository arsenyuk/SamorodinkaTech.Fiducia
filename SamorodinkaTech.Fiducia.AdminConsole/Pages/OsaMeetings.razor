    private bool CanSaveEdit
        => !editHasBoard
           || ((!editShareholdersCount.HasValue || editShareholdersCount.Value > 0)
               && (!editIsPao || !editShareholdersCount.HasValue || editShareholdersCount.Value <= 50
                   || (editShareholdersCount.HasValue && editShareholdersCount.Value > 50 && editIsPao))
               && (!editBoardMinNumber.HasValue || !editBoardMemberNumber.HasValue
                   || editBoardMemberNumber.Value >= editBoardMinNumber.Value));

    private int? DeriveBoardMinimum(string? okopfCode, int? shareholdersCount)
    {
        if (string.IsNullOrWhiteSpace(okopfCode)) return null;
        var normalized = new string(okopfCode.Where(char.IsDigit).ToArray());

        int baseMin = normalized switch
        {
            "12247" => 5,
            "12267" or "12260" => 3,
            "12300" => 2,
            _ => 3
        };

        if (normalized is "12247" or "12267" or "12260")
        {
            if (shareholdersCount > 10000) baseMin = Math.Max(baseMin, 9);
            else if (shareholdersCount > 1000) baseMin = Math.Max(baseMin, 7);
        }

        return baseMin;
    }

