@page "/admin/osa-meetings"
@implements IDisposable
@using Microsoft.EntityFrameworkCore
@using SamorodinkaTech.Fiducia.Domain.Entities
@inject IDbContextFactory<SamorodinkaTech.Fiducia.Infrastructure.Persistence.FiduciaDbContext> DbFactory
@inject SamorodinkaTech.Fiducia.Domain.Interfaces.ILegalEntityGosaIntervalService GosaSvc
@inject SamorodinkaTech.Fiducia.Domain.Interfaces.IFileStorage FileStorage
@inject ILogger<OsaMeetings> Logger
@inject NavigationManager Nav
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SYS_ADMIN")]

<h3>Общие собрания акционеров</h3>

@* === Режим редактирования === *@
@if (editingMeetingId.HasValue)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">
                    Редактирование ОСА —
                    @osaForms.FirstOrDefault(f => f.Id == editingFormId)?.Name
                </h5>
                <button class="btn btn-sm btn-outline-secondary" @onclick="BackToList">← К списку</button>
            </div>

            <ul class="nav nav-tabs mb-3">
                @{
                    // Вычисляем цепочку достижимости: вкладка idx достижима, если все предыдущие прошли валидацию
                    var stepReachable = new bool[wizardSteps.Length];
                    stepReachable[0] = true;
                    for (int i = 1; i < wizardSteps.Length; i++)
                        stepReachable[i] = stepReachable[i - 1] && IsStepValid(i - 1);
                }
                @foreach (var step in wizardSteps)
                {
                    var idx = Array.IndexOf(wizardSteps, step);
                    var active = idx == currentStep;
                    var done = idx < currentStep;
                    var reachable = stepReachable[idx];
                    var tabClass = active
                        ? (CanAdvance ? "active fw-bold text-success" : "active fw-bold border-warning")
                        : (done || reachable) ? "text-success"
                        : "text-muted";
                    var tabClickable = reachable && idx != currentStep && !isFinalized;
                    var tabDisabled = isFinalized || (!tabClickable && idx != currentStep);
                    <li class="nav-item">
                        <button type="button"
                                class="nav-link @tabClass"
                                style="cursor:@(tabClickable ? "pointer" : "default")"
                                disabled="@tabDisabled"
                                @onclick="() => GoToStep(idx)">
                            @if (idx < currentStep) { <span class="text-success me-1">✓</span> }
                            else if (reachable && idx > currentStep) { <span class="text-success me-1">→</span> }
                            @step
                        </button>
                    </li>
                }
            </ul>

            @if (currentStep == 0)
            {
            @if (editIsGosa && !editAbsenteeVoting)
            {
                <div class="mb-3">
                    <div class="row g-3 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Начало ОСА</label>
                            <InputDate @bind-Value="editGosaStart" class="form-control" />
                        </div>
                        <div class="col-auto">
                            <label class="form-label">Завершение ОСА</label>
                            <InputDate @bind-Value="editGosaEnd" class="form-control" />
                        </div>
                        <div class="col-auto">
                            @if (!string.IsNullOrEmpty(gosaError))
                            {
                                <span class="text-danger small">@gosaError</span>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (!editIsGosa)
            {
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editAbsentee" @bind="editAbsenteeVoting" />
                    <label class="form-check-label" for="editAbsentee">Заочное голосование</label>
                    @if (editAbsenteeVoting)
                    {
                        <span class="ms-3">
                            <label class="form-label small mb-0">Дата окончания приема бюллетеней</label>
                            <InputDate @bind-Value="editBallotDeadline" class="form-control form-control-sm d-inline-block ms-2" style="width:180px" />
                        </span>
                    }
                </div>
            }
            }

            @if (currentStep == 1)
            {
            @if (editHasBoard)
            {
            <div class="mb-3">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editShareholdersList" @bind="editShareholdersListReceived" />
                    <label class="form-check-label" for="editShareholdersList">Список акционеров получен</label>
                </div>
                <div class="row g-3 align-items-end mb-2">
                    <div class="col-12 col-md-4 col-lg-3 text-md-end text-muted">
                        <label class="form-label mb-0">Количество акционеров</label>
                    </div>
                    <div class="col-12 col-md-4 col-lg-4 d-flex justify-content-md-center">
                        <input class="form-control" style="max-width:110px" type="number" min="0" step="1" @bind="editShareholdersCount" disabled="@(!editShareholdersListReceived)" />
                    </div>
                    <div class="col-12 col-md-4 col-lg-5">
                        <div class="text-danger small">
                            @if (editShareholdersCount.HasValue && editShareholdersCount.Value <= 0)
                            {
                                <span>Укажите количество акционеров</span>
                            }
                            else if (!editIsPao && editShareholdersCount.HasValue && editShareholdersCount.Value > 50)
                            {
                                <span>Максимум 50 акционеров</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="row g-3 align-items-end mb-2">
                    <div class="col-12 col-md-4 col-lg-3 text-md-end text-muted">
                        <label class="form-label mb-0">Количество участников СД</label>
                    </div>
                    <div class="col-12 col-md-4 col-lg-4 d-flex justify-content-md-center">
                        <input class="form-control" style="max-width:110px" type="number" min="0" value="@editBoardMemberNumber" @oninput="OnBoardMemberNumberInput" disabled="@(!editShareholdersListReceived)" />
                    </div>
                    <div class="col-12 col-md-4 col-lg-5">
                        <div class="small">
                            @if (editBoardMemberNumber.HasValue && editBoardMinNumber.HasValue && editBoardMemberNumber.Value < editBoardMinNumber.Value)
                            {
                                <span class="text-danger">Минимум: @editBoardMinNumber</span>
                            }
                            else if (editBoardMinNumber.HasValue)
                            {
                                <span class="text-muted">Минимум: @editBoardMinNumber</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
            }
            }

            @if (currentStep == 2)
            {
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="editOsaHeld" @bind="editOsaHeld" @bind:after="OnOsaHeldChanged" />
                <label class="form-check-label" for="editOsaHeld">ОСА проведено</label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="editProtocolSigned" @bind="editProtocolSigned" disabled="@(!editOsaHeld)" />
                <label class="form-check-label" for="editProtocolSigned">Протокол подписан</label>
                @if (editProtocolSigned)
                {
                    <span class="ms-3">
                        <label class="form-label small mb-0">Дата подписания протокола</label>
                        <InputDate @bind-Value="editProtocolSignedAt" class="form-control form-control-sm d-inline-block ms-2" style="width:180px" />
                    </span>
                }
            </div>
            }

            @if (currentStep == 3)
            {
            <div class="mb-3">
                @if (editHasBoard && editProtocolSigned)
                {
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editBoardComposition" @bind="editBoardCompositionApproved" disabled="@editBoardMandatory" @bind:after="OnBoardCompositionChanged" />
                    <label class="form-check-label" for="editBoardComposition">
                        Состав СД утверждён
                        @if (editBoardMandatory)
                        {
                            <span class="badge bg-warning text-dark ms-1">Обязателен</span>
                        }
                    </label>
                </div>
                }
                @if (editBoardCompositionApproved)
                {
                <div class="fw-bold mb-1">Штатный состав СД</div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editDeputyChair" @bind="editDeputyChairProvided" />
                    <label class="form-check-label" for="editDeputyChair">Предусмотрен заместитель председателя</label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editSecretary" @bind="editSecretaryProvided" @bind:after="OnSecretaryChanged" />
                    <label class="form-check-label" for="editSecretary">Предусмотрен секретарь СД</label>
                </div>
                @if (editSecretaryProvided)
                {
                    <div class="form-check mb-2 ms-4">
                        <input class="form-check-input" type="checkbox" id="editSecretarySigns" @bind="editSecretarySignsProtocols" />
                        <label class="form-check-label" for="editSecretarySigns">Секретарь СД подписывает протоколы</label>
                    </div>
                }
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="editTempChair" @bind="editTemporaryChairProvided" @bind:after="OnTempChairChanged" />
                    <label class="form-check-label" for="editTempChair">Предусмотрен временный председательствующий</label>
                </div>
                @if (editTemporaryChairProvided)
                {
                    <div class="ms-4 mb-2">
                        <label class="form-label small mb-0">Способ выбора</label>
                        <select class="form-select form-select-sm" style="max-width:350px" @bind="editTemporaryChairSelection">
                            <option value="CHARTER_SENIOR">По уставу — старший по возрасту</option>
                            <option value="GMS_DECISION">По решению ОСА</option>
                            <option value="BOARD_ELECTION">По решению СД</option>
                        </select>
                    </div>
                }
                }
            </div>

            @if (editBoardCompositionApproved)
            {
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="fw-bold">Состав СД</span>
                    </div>
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th style="width:28%">ФИО</th>
                                <th style="width:22%">Должность</th>
                                <th style="width:20%">Тип участника</th>
                                <th style="width:20%">Роль в СД</th>
                                <th style="width:10%">С</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < boardMemberRows.Count; i++)
                            {
                                <tr>
                                    <td><input class="form-control form-control-sm" @bind="boardMemberRows[i].Name" /></td>
                                    <td><input class="form-control form-control-sm" @bind="boardMemberRows[i].Position" /></td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                value="@(boardMemberRows[i].MemberTypeId?.ToString())"
                                                @onchange="e => OnMemberTypeChanged(i, e)">
                                            <option value="">—</option>
                                            @foreach (var t in memberTypes)
                                            {
                                                <option value="@t.Id">@t.Name</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <select class="form-select form-select-sm"
                                                value="@(boardMemberRows[i].RoleId?.ToString())"
                                                @onchange="e => OnRoleChanged(i, e)">
                                            <option value="">—</option>
                                            @foreach (var r in boardRoles)
                                            {
                                                <option value="@r.Id">@r.Name</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input class="form-control form-control-sm" @bind="boardMemberRows[i].StartedAt" placeholder="дд.мм.гггг" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            }

            @if (currentStep == 4)
            {
            @* Файлы *@
            <fieldset class="border rounded p-3 mb-3">
                <legend class="float-none w-auto px-2 mb-0">Файлы</legend>
                @if (editIsGosa && !editHasBoard)
                {
                    <div class="alert alert-info py-2 mb-2 small">
                        СД отсутствует (функции СД выполняет ОСА по уставу, п. 1 ст. 64 Закона об АО) —
                        прикладывание файлов необязательно.
                    </div>
                }
                else if (editIsGosa)
                {
                    <div class="alert alert-warning py-2 mb-2 small">
                        Для ГОСА обязателен юридически значимый документ (ЮЗД) с информацией о составе СД.
                    </div>
                }
                @if (meetingFiles.Any())
                {
                    <table class="table table-sm">
                        <thead><tr><th>Тип</th><th>Наименование</th><th>Имя файла</th><th>Размер</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var mf in meetingFiles)
                        {
                            <tr>
                                <td><span class="badge @FileTypeBadge(mf.FileType)">@FileTypeLabel(mf.FileType)</span></td>
                                <td>@(mf.DisplayName ?? "—")</td>
                                <td>@mf.FileName</td>
                                <td>@FormatSize(mf.SizeBytes)</td>
                                <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFile(mf.Id)">Удалить</button></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-muted small mb-2">Файлы не прикреплены.</div>
                }
                <div class="d-flex gap-2 align-items-end">
                    <div>
                        <label class="form-label small">Тип файла</label>
                        <select class="form-select form-select-sm" @bind="newFileType">
                            <option value="CHARTER">Устав</option>
                            <option value="PROTOCOL">Протокол</option>
                            <option value="REGULATION">Положение</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label small">Наименование</label>
                        <input class="form-control form-control-sm" @bind="newFileDisplayName" placeholder="Название документа" />
                    </div>
                    <div>
                        <label class="form-label small">Файл</label>
                        <InputFile class="form-control form-control-sm" OnChange="OnFileSelected" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" />
                    </div>
                </div>
                @if (uploadProgress > 0 && uploadProgress < 100)
                {
                    <div class="progress flex-grow-1 mt-1" style="max-width:200px">
                        <div class="progress-bar" style="width:@uploadProgress%">@uploadProgress%</div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(fileError))
                {
                    <span class="text-danger small">@fileError</span>
                }
            </fieldset>
            }

            @if (currentStep == 5)
            {
                <div class="alert alert-info">
                    <strong>Финализация ОСА.</strong> После нажатия «Завершить» редактирование будет заблокировано.
                    Действия сотрудника основаны на юридически значимых документах (ЮЗД), переданных для ввода информации.
                </div>
                if (!isFinalized)
                {
                    <button class="btn btn-success" @onclick="Finalize">Завершить</button>
                }
                else
                {
                    <div class="alert alert-success">ОСА зафиксирована @finalizedAt?.ToString("dd.MM.yyyy HH:mm")</div>
                }
            }

            @if (!string.IsNullOrEmpty(saveError))
            {
                <div class="alert alert-danger">@saveError</div>
            }
            @if (!string.IsNullOrEmpty(saveSuccess))
            {
                <div class="alert alert-success">@saveSuccess</div>
            }

            <div class="d-flex gap-2">
                @if (!isFinalized)
                {
                    <button class="btn btn-outline-primary" @onclick="PrevStep" disabled="@(currentStep == 0)">← Назад</button>
                    @if (currentStep < wizardSteps.Length - 1)
                    {
                        <button class="btn btn-primary" @onclick="NextStep" disabled="@(!CanAdvance)">Далее →</button>
                    }
                    <button class="btn btn-danger ms-auto" @onclick="Delete">Удалить</button>
                }
            </div>
        </div>
    </div>
}

@* === Режим создания === *@
@if (showForm)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Новое ОСА</h5>
            <div class="mb-3">
                <label class="form-label">Тип</label>
                <select class="form-select" @onchange="OnOsaTypeChanged">
                    <option value="" selected="@(selectedOsaFormId == Guid.Empty)">— Выберите тип —</option>
                    @foreach (var form in osaForms)
                    {
                        <option value="@form.Id">@form.Name</option>
                    }
                </select>
            </div>

            @if (selectedFormCode == "GOSA")
            {
                <div class="mb-3">
                    <div class="row g-3 align-items-end">
                        <div class="col-auto">
                            <label class="form-label">Начало ОСА</label>
                            <InputDate @bind-Value="gosaStart" class="form-control" />
                        </div>
                        <div class="col-auto">
                            <label class="form-label">Завершение ОСА</label>
                            <InputDate @bind-Value="gosaEnd" class="form-control" />
                        </div>
                        <div class="col-auto">
                            @if (!string.IsNullOrEmpty(gosaError))
                            {
                                <span class="text-danger small">@gosaError</span>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (selectedFormCode == "VOSA")
            {
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="createAbsentee" @bind="createAbsenteeVoting" />
                    <label class="form-check-label" for="createAbsentee">Заочное голосование</label>
                    @if (createAbsenteeVoting)
                    {
                        <span class="ms-3">
                            <label class="form-label small mb-0">Дата окончания приема бюллетеней</label>
                            <InputDate @bind-Value="createBallotDeadline" class="form-control form-control-sm d-inline-block ms-2" style="width:180px" />
                        </span>
                    }
                </div>
            }

            <div class="d-flex gap-2">
                <button class="btn btn-success" @onclick="Save" disabled="@(selectedOsaFormId == Guid.Empty)">Сохранить</button>
                <button class="btn btn-secondary" @onclick="CancelForm">Отмена</button>
            </div>
        </div>
    </div>
}

@* === Список === *@
@if (!editingMeetingId.HasValue && !showForm)
{
    <button class="btn btn-primary mb-3" @onclick="OpenForm">Добавить</button>
}

@if (!editingMeetingId.HasValue)
{
    if (!string.IsNullOrEmpty(saveError))
    {
        <div class="alert alert-danger">@saveError</div>
    }
    if (!string.IsNullOrEmpty(saveSuccess))
    {
        <div class="alert alert-success">@saveSuccess</div>
    }

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Тип ОСА</th>
                <th>Дата закрытия заседания</th>
                <th>Дата создания</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (!osaMeetings.Any())
        {
            <tr><td colspan="4" class="text-muted">Записей ОСА пока нет.</td></tr>
        }
        else
        {
            @foreach (var m in osaMeetings)
            {
                <tr>
                    <td>@m.FormName</td>
                    <td>
                        @if (m.GosaWindowEnd.HasValue)
                        {
                            <span>@m.GosaWindowEnd.Value.ToString("dd.MM")</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>@m.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td><button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEdit(m.Id)">Редактировать</button>
                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteFromList(m.Id)">Удалить</button></td>
                </tr>
            }
        }
        </tbody>
    </table>
}

@code {
    private List<OsaForm> osaForms = new();
    private List<OsaMeetingVm> osaMeetings = new();

    // Режим создания
    private bool showForm;
    private Guid selectedOsaFormId;
    private string? selectedFormCode;
    private DateOnly gosaStart;
    private DateOnly gosaEnd;
    private bool createAbsenteeVoting;
    private DateTime createBallotDeadline = DateTime.UtcNow.AddDays(20);
    private DateTime? editBallotDeadline;

    // Режим редактирования
    private Guid? editingMeetingId;
    private Guid editingFormId;
    private bool editIsGosa;
    private DateOnly editGosaStart;
    private DateOnly editGosaEnd;
    private int? editShareholdersCount;
    private int? editBoardMemberNumber;
    private int? editBoardMinNumber;
    private string? editOkopfCode;
    private bool editIsPao;
    private bool editHasBoard;
    private bool editShareholdersListReceived;
    private bool editAbsenteeVoting;
    private bool editBoardMandatory;
    private bool editBoardCompositionApproved;
    private bool editOsaHeld;
    private bool editProtocolSigned;
    private DateTime? editProtocolSignedAt;
    private bool editDeputyChairProvided;
    private bool editSecretaryProvided = true;
    private bool editSecretarySignsProtocols;
    private bool editTemporaryChairProvided;
    private string? editTemporaryChairSelection = "CHARTER_SENIOR";
    private List<BoardMemberRow> boardMemberRows = new();
    private List<BoardMemberType> memberTypes = new();
    private List<BoardRole> boardRoles = new();
    private bool isFinalized;
    private DateTime? finalizedAt;

    // Мастер
    private int currentStep;
    private static readonly string[] wizardSteps = { "Параметры", "Проведение", "Протокол", "Состав СД", "Файлы", "Финализация" };

    private async Task GoToStep(int step)
    {
        Logger.LogDebug("GoToStep вызван: step={Step}, currentStep={Current}, isFinalized={Finalized}", step, currentStep, isFinalized);
        if (isFinalized) return;
        if (step == currentStep) return;

        // Вперёд: все промежуточные шаги должны пройти валидацию
        if (step > currentStep)
        {
            for (int i = currentStep; i < step; i++)
            {
                if (!IsStepValid(i))
                {
                    Logger.LogDebug("GoToStep заблокирован: шаг {Step} не прошёл валидацию", i);
                    return;
                }
            }
        }

        await QuickSave();
        currentStep = step;
        StateHasChanged();
        Logger.LogDebug("GoToStep переход выполнен: currentStep={Current}", currentStep);
    }

    /// <summary>Валидность контента шага (пройдена ли валидация для перехода дальше).</summary>
    private bool IsStepValid(int step) => step switch
    {
        0 => true,
        1 => !editHasBoard || (editShareholdersListReceived && editShareholdersCount.HasValue),
        2 => editProtocolSigned && editProtocolSignedAt.HasValue,
        3 => !editHasBoard || !editBoardMandatory || (editBoardCompositionApproved && AreBoardMemberFieldsValid()),
        4 => !editIsGosa || !editHasBoard || meetingFiles.Any(),
        _ => true
    };

    /// <summary>Клиентская валидация: все поля членов с ролью «Член СД» заполнены.</summary>
    private bool AreBoardMemberFieldsValid()
    {
        if (!editBoardCompositionApproved || !editHasBoard) return true;
        var roleId = memberRoleId;
        if (roleId is null) return true;
        var members = boardMemberRows.Where(r => r.RoleId == roleId).ToList();
        if (!members.Any()) return true;
        return members.All(r =>
            !string.IsNullOrWhiteSpace(r.Name)
            && !string.IsNullOrWhiteSpace(r.Position)
            && r.MemberTypeId.HasValue
            && !string.IsNullOrWhiteSpace(r.StartedAt));
    }

    private bool CanAdvance => IsStepValid(currentStep);

    private async Task NextStep()
    {
        if (isFinalized) return;
        if (currentStep < wizardSteps.Length - 1)
        {
            await QuickSave();
            currentStep++;
        }
    }

    private async Task PrevStep()
    {
        if (isFinalized) return;
        if (currentStep > 0)
        {
            await QuickSave();
            currentStep--;
        }
    }

    private async Task Finalize()
    {
        if (!editingMeetingId.HasValue || isFinalized) return;
        try
        {
            await QuickSave();
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var m = await ctx.OsaMeetings.FirstOrDefaultAsync(x => x.Id == editingMeetingId.Value);
            if (m is null) return;
            m.Status = "APPROVED";
            m.FinalizedAt = DateTime.UtcNow;
            // TODO: получить ID текущего пользователя
            await ctx.SaveChangesAsync();
            isFinalized = true;
            finalizedAt = m.FinalizedAt.Value.ToLocalTime();
            saveSuccess = "ОСА зафиксирована.";
        }
        catch (Exception ex)
        {
            saveError = ex.Message;
        }
    }

    private async Task QuickSave()
    {
        if (!editingMeetingId.HasValue) return;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var m = await ctx.OsaMeetings.FirstOrDefaultAsync(x => x.Id == editingMeetingId.Value);
            if (m is null) return;

            if (editIsGosa) { m.GosaWindowStart = editGosaStart; m.GosaWindowEnd = editGosaEnd; }
            m.AbsenteeVoting = editAbsenteeVoting;
            m.BallotDeadline = editAbsenteeVoting && editBallotDeadline.HasValue ? ((DateTime)editBallotDeadline).ToUniversalTime() : null;
            m.ShareholdersListReceived = editShareholdersListReceived;
            m.ShareholdersCount = editHasBoard ? editShareholdersCount : null;
            m.BoardMemberNumber = editHasBoard ? editBoardMemberNumber : null;
            m.OsaHeld = editOsaHeld;
            m.ProtocolSigned = editProtocolSigned && editOsaHeld;
            m.ProtocolSignedAt = editProtocolSigned && editProtocolSignedAt.HasValue ? ((DateTime)editProtocolSignedAt).ToUniversalTime() : null;
            m.DeputyChairProvided = editDeputyChairProvided;
            m.SecretaryProvided = editSecretaryProvided;
            m.SecretarySignsProtocols = editSecretaryProvided && editSecretarySignsProtocols;
            m.TemporaryChairProvided = editTemporaryChairProvided;
            m.TemporaryChairSelection = editTemporaryChairProvided ? editTemporaryChairSelection : null;
            m.BoardCompositionApproved = editBoardCompositionApproved;

            await ctx.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "QuickSave: ошибка сохранения ОСА {OsaMeetingId}", editingMeetingId);
        }
    }

