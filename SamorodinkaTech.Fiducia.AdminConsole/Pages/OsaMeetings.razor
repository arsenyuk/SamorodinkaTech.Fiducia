    private async Task SaveEdit()
    {
        if (!editingMeetingId.HasValue) return;
        saveError = null;
        saveSuccess = null;
        gosaError = null;

        Logger.LogDebug("Серверная валидация ОСА редактирование {OsaMeetingId}", editingMeetingId.Value);

        // Серверная валидация ОСА (BDR‑008) — только если СД существует
        if (editHasBoard)
        {
            var validationModel = new SamorodinkaTech.Fiducia.Domain.Validation.OsaMeetingValidationModel
            {
                ShareholdersCount = editShareholdersCount,
                OkopfCode = editOkopfCode,
                BoardMinNumber = editBoardMinNumber,
                BoardMemberNumber = editBoardMemberNumber,
                HasGosaInterval = editIsGosa && !editAbsenteeVoting,
                IsAbsentee = editAbsenteeVoting
            };
            var validation = SamorodinkaTech.Fiducia.Domain.Validation.OsaMeetingValidator.Validate(validationModel);
            if (!validation.IsValid)
            {
                Logger.LogWarning("Валидация не пройдена для ОСА {OsaMeetingId}: {Errors}",
                    editingMeetingId.Value, string.Join("; ", validation.Errors));
                saveError = string.Join(" ", validation.Errors);
                return;
            }
        }

        if (editIsGosa)
        {
            var (defStart, defEnd) = GosaSvc.GetDefaultWindow();
            if (editGosaStart < defStart || editGosaEnd > defEnd)
            {
                gosaError = $"Даты должны быть в пределах {defStart:dd.MM}–{defEnd:dd.MM}";
                Logger.LogWarning("Валидация не пройдена для ОСА {OsaMeetingId}: {Errors}", editingMeetingId.Value, gosaError);
                return;
            }
            if (editGosaEnd < editGosaStart)
            {
                gosaError = "Завершение ОСА не может быть раньше начала ОСА";
                Logger.LogWarning("Валидация не пройдена для ОСА {OsaMeetingId}: {Errors}", editingMeetingId.Value, gosaError);
                return;
            }
        }

        if (editProtocolSigned && editProtocolSignedAt.HasValue && editProtocolSignedAt > DateTime.Now)
        {
            saveError = "Дата подписания протокола не может быть в будущем";
            return;
        }

        if (editProtocolSigned && editProtocolSignedAt.HasValue)
        {
            var referenceDate = editAbsenteeVoting && editBallotDeadline.HasValue
                ? editBallotDeadline.Value
                : (editIsGosa ? editGosaEnd.ToDateTime(TimeOnly.MinValue) : DateTime.MinValue);

            if (referenceDate != DateTime.MinValue)
            {
                var signedAt = (DateTime)editProtocolSignedAt;
                var deadline = referenceDate.AddDays(3);
                if (signedAt < referenceDate)
                {
                    saveError = "Дата подписания протокола не может быть раньше даты завершения ОСА";
                    return;
                }
                if (signedAt > deadline)
                {
                    saveError = $"Дата подписания протокола не может быть позднее {deadline:dd.MM.yyyy} (3 дня после завершения ОСА)";
                    return;
                }
            }
        }

        if (editBoardMandatory && !editBoardCompositionApproved)
        {
            saveError = "Для данного типа ЮЛ состав СД должен быть утверждён";
            return;
        }

        // Серверная валидация полей членов СД с ролью «Член СД»
        if (editBoardCompositionApproved && editHasBoard)
        {
            var roleId = memberRoleId;
            if (roleId.HasValue)
            {
                var members = boardMemberRows.Where(r => r.RoleId == roleId.Value).ToList();
                foreach (var row in members)
                {
                    if (string.IsNullOrWhiteSpace(row.Name)
                        || string.IsNullOrWhiteSpace(row.Position)
                        || !row.MemberTypeId.HasValue
                        || string.IsNullOrWhiteSpace(row.StartedAt))
                    {
                        saveError = "Для членов СД должны быть заполнены все поля (ФИО, должность, тип участника, роль, дата начала полномочий)";
                        Logger.LogWarning("Валидация не пройдена для состава СД {OsaMeetingId}: незаполненные поля у члена {Name}",
                            editingMeetingId, row.Name);
                        return;
                    }
                }
            }
        }

        if (editIsGosa && !meetingFiles.Any())
        {
            saveError = "Для ГОСА необходимо прикрепить хотя бы один юридически значимый документ (ЮЗД) с информацией о составе СД";
            return;
        }

        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var m = await ctx.OsaMeetings.FirstOrDefaultAsync(x => x.Id == editingMeetingId.Value);
            if (m is null) return;

            if (editIsGosa)
            {
                m.GosaWindowStart = editGosaStart;
                m.GosaWindowEnd = editGosaEnd;
            }

            m.ShareholdersCount = editHasBoard ? editShareholdersCount : null;
            m.BoardMemberNumber = editHasBoard ? editBoardMemberNumber : null;
            m.ShareholdersListReceived = editShareholdersListReceived;
            m.AbsenteeVoting = editAbsenteeVoting;
            m.BallotDeadline = editAbsenteeVoting && editBallotDeadline.HasValue
                ? ((DateTime)editBallotDeadline).ToUniversalTime() : null;
            m.OsaHeld = editOsaHeld;
            m.ProtocolSigned = editProtocolSigned && editOsaHeld;
            m.DeputyChairProvided = editDeputyChairProvided;
            m.SecretaryProvided = editSecretaryProvided;
            m.SecretarySignsProtocols = editSecretaryProvided && editSecretarySignsProtocols;
            m.TemporaryChairProvided = editTemporaryChairProvided;
            m.TemporaryChairSelection = editTemporaryChairProvided ? editTemporaryChairSelection : null;
            m.BoardCompositionApproved = editBoardCompositionApproved;
            m.ProtocolSignedAt = editProtocolSigned && editProtocolSignedAt.HasValue
                ? ((DateTime)editProtocolSignedAt).ToUniversalTime() : null;

            // Обновляем состав СД: удаляем старых, создаём новых
            var oldMembers = await ctx.BoardMembers.Where(x => x.OsaMeetingId == editingMeetingId.Value).ToListAsync();
            var oldMemberIds = oldMembers.Select(x => x.Id).ToList();
            var oldAppointments = await ctx.BoardMemberAppointments.Where(x => oldMemberIds.Contains(x.BoardMemberId)).ToListAsync();
            ctx.BoardMemberAppointments.RemoveRange(oldAppointments);
            ctx.BoardMembers.RemoveRange(oldMembers);
            foreach (var row in boardMemberRows.Where(x => !string.IsNullOrWhiteSpace(x.Name)))
            {
                var member = new BoardMember
                {
                    Id = Guid.NewGuid(),
                    OsaMeetingId = editingMeetingId.Value,
                    FullName = row.Name.Trim(),
                    Position = string.IsNullOrWhiteSpace(row.Position) ? null : row.Position.Trim(),
                    BoardMemberTypeId = row.MemberTypeId
                };
                ctx.BoardMembers.Add(member);

                if (row.RoleId.HasValue && row.StartedAt is not null && DateOnly.TryParse(row.StartedAt, out var startedAt))
                {
                    ctx.BoardMemberAppointments.Add(new BoardMemberAppointment
                    {
                        Id = Guid.NewGuid(),
                        BoardMemberId = member.Id,
                        RoleId = row.RoleId.Value,
                        StartedAt = startedAt,
                        Status = "ACTIVE"
                    });
                }
            }

            await ctx.SaveChangesAsync();
            saveSuccess = "Изменения сохранены.";
            await LoadData();
        }
        catch (Exception ex)
        {
            saveError = ex.Message;
        }
    }

