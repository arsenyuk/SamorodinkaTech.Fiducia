    private async Task LoadMeetingFiles()
    {
        if (!editingMeetingId.HasValue) return;
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            meetingFiles = await ctx.Set<OsaMeetingFile>()
                .Where(x => x.OsaMeetingId == editingMeetingId.Value)
                .Include(x => x.File)
                .Select(x => new MeetingFileVm
                {
                    Id = x.Id,
                    FileType = x.FileType,
                    DisplayName = x.DisplayName,
                    FileName = x.File!.OriginalName,
                    SizeBytes = x.File.SizeBytes
                })
                .ToListAsync();
        }
        catch
        {
            meetingFiles = new();
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        fileError = null;
        uploadProgress = 0;

        var browserFile = e.File;
        if (browserFile.Size > 50_000_000)
        {
            fileError = "Файл слишком большой (макс. 50 МБ)";
            return;
        }

        try
        {
            // Читаем чанками по 512 КБ
            const int chunkSize = 512 * 1024;
            await using var stream = browserFile.OpenReadStream(maxAllowedSize: 50_000_000);
            await using var ms = new MemoryStream();
            var buffer = new byte[chunkSize];
            int bytesRead;

            while ((bytesRead = await stream.ReadAsync(buffer)) > 0)
            {
                await ms.WriteAsync(buffer.AsMemory(0, bytesRead));
                uploadProgress = (int)((double)ms.Length / browserFile.Size * 100);
                StateHasChanged();
            }

            ms.Position = 0;
            var storageKey = await FileStorage.SaveAsync(ms, browserFile.Name, browserFile.ContentType, CancellationToken.None);

            // Сохраняем метаданные и связь с ОСА
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var fileEntry = new FileEntry
            {
                Id = Guid.NewGuid(),
                OriginalName = browserFile.Name,
                ContentType = browserFile.ContentType,
                SizeBytes = browserFile.Size,
                StorageProvider = "LOCAL",
                StorageKeyOrPath = storageKey
            };
            ctx.Files.Add(fileEntry);

            var meetingFile = new OsaMeetingFile
            {
                Id = Guid.NewGuid(),
                OsaMeetingId = editingMeetingId!.Value,
                FileId = fileEntry.Id,
                FileType = newFileType,
                DisplayName = string.IsNullOrWhiteSpace(newFileDisplayName) ? null : newFileDisplayName.Trim()
            };
            ctx.Set<OsaMeetingFile>().Add(meetingFile);

            await ctx.SaveChangesAsync();

            uploadProgress = 100;
            fileError = null;
            await LoadMeetingFiles();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            fileError = ex.Message;
        }
    }

    private async Task DeleteFile(Guid meetingFileId)
    {
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var mf = await ctx.Set<OsaMeetingFile>()
                .Include(x => x.File)
                .FirstOrDefaultAsync(x => x.Id == meetingFileId);
            if (mf is null) return;

            // Удаляем из хранилища
            await FileStorage.DeleteAsync(mf.File!.StorageKeyOrPath, CancellationToken.None);

            ctx.Set<OsaMeetingFile>().Remove(mf);
            ctx.Files.Remove(mf.File);
            await ctx.SaveChangesAsync();

            await LoadMeetingFiles();
        }
        catch (Exception ex)
        {
            fileError = ex.Message;
        }
    }

