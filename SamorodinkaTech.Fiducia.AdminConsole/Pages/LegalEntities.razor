    private async Task LoadSparkData()
    {
        if (string.IsNullOrEmpty(selectedEntity?.Inn)) return;
        sparkLoading = true;
        sparkError = null;
        StateHasChanged();

        try
        {
            var inn = selectedEntity.Inn.Trim();
            var company = await SparkApi.GetCompanyByInnAsync(inn);
            var manager = await SparkApi.GetManagerAsync(inn);

            await using var ctx = await DbFactory.CreateDbContextAsync();

            // Сохраняем карточку компании в ext_spark_company (BDR-009)
            if (company is not null)
            {
                var existing = await ctx.ExtSparkCompanies.FirstOrDefaultAsync(x => x.Inn == inn);
                if (existing is null)
                {
                    ctx.ExtSparkCompanies.Add(new SamorodinkaTech.Fiducia.Domain.Entities.ExtSparkCompany
                    {
                        Id = Guid.NewGuid(),
                        Inn = company.Inn,
                        Ogrn = company.Ogrn,
                        FullName = company.FullName,
                        ShortName = company.ShortName,
                        OkopfCode = company.OkopfCode,
                        OkopfName = company.OkopfName,
                        LegalAddress = company.LegalAddress,
                        Status = company.Status,
                        RegistrationDate = company.RegistrationDate,
                        ShareholdersCount = company.ShareholdersCount,
                        EmployeesCount = company.EmployeesCount,
                        FetchedAt = DateTime.UtcNow
                    });
                }
                else
                {
                    existing.Ogrn = company.Ogrn;
                    existing.FullName = company.FullName;
                    existing.ShortName = company.ShortName;
                    existing.OkopfCode = company.OkopfCode;
                    existing.OkopfName = company.OkopfName;
                    existing.LegalAddress = company.LegalAddress;
                    existing.Status = company.Status;
                    existing.RegistrationDate = company.RegistrationDate;
                    existing.ShareholdersCount = company.ShareholdersCount;
                    existing.EmployeesCount = company.EmployeesCount;
                    existing.FetchedAt = DateTime.UtcNow;
                }
                _sparkCompanyFullName = company.FullName;
                _sparkCompanyShortName = company.ShortName;
                _sparkCompanyOgrn = company.Ogrn;
                _sparkCompanyOkopfName = company.OkopfName;
                _sparkCompanyAddress = company.LegalAddress;
                _sparkCompanyStatus = company.Status;
                _sparkCompanyRegDate = company.RegistrationDate;

                // Обновляем ОКОПФ в legal_entities, если найден в СПАРК
                if (!string.IsNullOrEmpty(company.OkopfCode))
                {
                    var normalizedCode = new string(company.OkopfCode.Where(char.IsDigit).ToArray());
                    var okopf = await ctx.Okopf.FirstOrDefaultAsync(o => o.Code == normalizedCode);
                    if (okopf is not null)
                    {
                        var le = await ctx.LegalEntities.FirstOrDefaultAsync(x => x.Id == selectedEntity.Id);
                        if (le is not null)
                        {
                            le.OkopfId = okopf.Id;
                            selectedEntity.Okopf = new OkopfVm { Code = okopf.Code, Name = okopf.Name };
                            _orgType = ResolveOrgTypeFromCode(okopf.Code);
                            editHasBoardOfDirectors = _orgType != OrgType.Unknown;
                        }
                    }
                    else
                    {
                        Logger.LogWarning("Код ОКОПФ из СПАРК не найден в справочнике: {OkopfCode}", company.OkopfCode);
                    }
                }
            }

            // Сохраняем руководителя в ext_spark_manager (BDR-009)
            if (manager is not null)
            {
                var existing = await ctx.ExtSparkManagers.FirstOrDefaultAsync(x => x.Inn == inn);
                if (existing is null)
                {
                    ctx.ExtSparkManagers.Add(new SamorodinkaTech.Fiducia.Domain.Entities.ExtSparkManager
                    {
                        Id = Guid.NewGuid(),
                        Inn = inn,
                        FullName = manager.FullName,
                        Position = manager.Position,
                        PersonInn = manager.Inn,
                        StartDate = manager.StartDate,
                        FetchedAt = DateTime.UtcNow
                    });
                }
                else
                {
                    existing.FullName = manager.FullName;
                    existing.Position = manager.Position;
                    existing.PersonInn = manager.Inn;
                    existing.StartDate = manager.StartDate;
                    existing.FetchedAt = DateTime.UtcNow;
                }

                editFullName = manager.FullName;
                editPosition = manager.Position ?? "Генеральный директор";
                _sparkManagerName = manager.FullName;
                _sparkManagerPosition = manager.Position;
                _sparkManagerInn = manager.Inn;
                _sparkManagerStartDate = manager.StartDate;
            }
            else
            {
                // Если руководитель не найден в API, пробуем загрузить из кэша ext_spark_manager
                var cachedManager = await ctx.ExtSparkManagers.FirstOrDefaultAsync(x => x.Inn == inn);
                if (cachedManager is not null)
                {
                    editFullName = cachedManager.FullName;
                    editPosition = cachedManager.Position ?? "Генеральный директор";
                    _sparkManagerName = cachedManager.FullName;
                    _sparkManagerPosition = cachedManager.Position;
                    _sparkManagerInn = cachedManager.PersonInn;
                    _sparkManagerStartDate = cachedManager.StartDate;
                }
                else
                {
                    sparkError = "Руководитель не найден в СПАРК";
                }
            }

            await ctx.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Ошибка загрузки данных из СПАРК для ИНН={Inn}", selectedEntity.Inn);
            sparkError = "Ошибка соединения со СПАРК";
        }
        finally
        {
            sparkLoading = false;
            StateHasChanged();
        }
    }

    private static OrgType ResolveOrgTypeFromCode(string? code)
    {
        var normalized = new string((code ?? string.Empty).Where(char.IsDigit).ToArray());
        return normalized switch
        {
            "12247" => OrgType.PAO,
            "12267" => OrgType.NAO_AO,
            "12260" => OrgType.NAO_AO,
            "12300" => OrgType.LLC,
            _ => OrgType.Unknown
        };
    }

    private async Task ResolveOrgTypeAsync(Guid legalEntityId)
    {
        try
        {
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var le = await ctx.LegalEntities.Include(x => x.Okopf).FirstOrDefaultAsync(x => x.Id == legalEntityId);
            var codeRaw = le?.Okopf?.Code ?? string.Empty;
            var normalized = new string(codeRaw.Where(char.IsDigit).ToArray());
            _orgType = normalized switch
            {
                "12247" => OrgType.PAO,
                "12267" => OrgType.NAO_AO,
                "12260" => OrgType.NAO_AO,
                "12300" => OrgType.LLC,
                _ => OrgType.Unknown
            };
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Ошибка определения типа ЮЛ {LegalEntityId}", legalEntityId);
        }
    }

    private async Task LoadGosaWindowAsync(Guid legalEntityId)
    {
        try
        {
            gosaError = null;
            await using var ctx = await DbFactory.CreateDbContextAsync();
            var le = await ctx.LegalEntities.Include(x => x.Okopf).FirstOrDefaultAsync(x => x.Id == legalEntityId);
            if (le is null) { gosaError = "ЮЛ не найдено"; return; }
            var settings = await ctx.LegalEntityBoardSettings.FirstOrDefaultAsync();
            var (defStart, defEnd) = GosaSvc.GetWindowForOkopf(le.Okopf?.Code);
            var s = settings?.GosaWindowStart ?? defStart;
            var e = settings?.GosaWindowEnd ?? defEnd;
            gosaStartMonth = s.Month;
            gosaStartDay = s.Day;
            gosaEndMonth = e.Month;
            gosaEndDay = e.Day;
            gosaIsPao = GosaSvc.IsPao(le.Okopf?.Code);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Ошибка загрузки интервала ГОСА");
            gosaError = ExceptionFlattener.Unwrap(ex);
        }
    }

    private void OnGosaDateChanged()
    {
        var isPao = gosaIsPao;
        if (!isPao) { gosaError = null; return; }
        gosaError = GosaSvc.ValidateForOkopf(null, GosaStart, GosaEnd)
            ? null
            : "Недопустимый интервал ГОСА для данной ОПФ";
    }

